@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<style>
    .auth-container {
        min-height: 80vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 2rem;
        position: relative;
    }

    /* Dynamic glowing orbs */
    .auth-container::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 10% 20%, rgba(111,0,255,0.2) 0%, transparent 40%),
                    radial-gradient(circle at 90% 80%, rgba(0,195,255,0.2) 0%, transparent 40%);
        filter: blur(60px);
        z-index: -1;
        pointer-events: none;
        animation: pulseOrbs 10s ease-in-out infinite alternate;
    }

    @@keyframes pulseOrbs {
        0% { transform: scale(1); opacity: 0.8; }
        100% { transform: scale(1.1); opacity: 1; }
    }

    /* Glass Card */
    .auth-card {
        width: 100%;
        max-width: 480px;
        padding: 45px;
        border-radius: 24px;
        background: var(--bs-body-bg);
        border: 1px solid var(--bs-border-color);
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    [data-bs-theme='dark'] .auth-card {
        background: rgba(30, 30, 36, 0.7);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }

    /* Glow bar on top of card */
    .auth-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, #6f00ff, #00c3ff);
    }

    .auth-title {
        font-weight: 700;
        margin-bottom: 2rem;
        font-size: 2rem;
        text-align: center;
        background: linear-gradient(90deg, #6f00ff, #00c3ff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* Inputs */
    .auth-input {
        background: var(--bs-tertiary-bg);
        border: 1px solid var(--bs-border-color);
        border-radius: 12px;
        padding: 12px 16px;
        color: var(--bs-body-color);
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .auth-input:focus {
        background: var(--bs-body-bg);
        border-color: #00c3ff;
        box-shadow: 0 0 0 4px rgba(0, 195, 255, 0.15);
        transform: translateY(-2px);
    }

    /* Modern Button */
    .auth-btn {
        width: 100%;
        padding: 14px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(135deg, #6f00ff 0%, #00c3ff 100%);
        color: white;
        font-weight: 600;
        font-size: 1.1rem;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 1rem;
        margin-bottom: 1.5rem;
    }

    .auth-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(111,0,255,0.3);
        background: linear-gradient(135deg, #7b1aff 0%, #1ad0ff 100%);
        color: white;
    }

    .auth-link {
        color: var(--bs-body-color);
        text-decoration: none;
        font-weight: 500;
        opacity: 0.8;
        transition: all 0.2s ease;
    }

    .auth-link:hover {
        color: #00c3ff;
        opacity: 1;
    }
</style>

<div class="auth-container">
    <div class="auth-card">
        <h2 class="auth-title">Create Account</h2>
        
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label class="form-label text-secondary fw-semibold small">Email Address</label>
                <input asp-for="Input.Email" class="form-control auth-input" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-4">
                <label class="form-label text-secondary fw-semibold small">Password</label>
                <input asp-for="Input.Password" class="form-control auth-input" placeholder="••••••••" type="password" />
                <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-4">
                <label class="form-label text-secondary fw-semibold small">Confirm Password</label>
                <input asp-for="Input.ConfirmPassword" class="form-control auth-input" placeholder="••••••••" type="password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small mt-1 d-block"></span>
            </div>

            <button type="submit" class="auth-btn">
                Register
            </button>

            <div class="text-center mt-2">
                <span class="text-secondary small">Already have an account?</span><br />
                <a asp-page="./Login" class="auth-link mt-1 d-inline-block">Log In here</a>
            </div>
        </form>
    </div>
</div>