@page
@model RegisterModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Register"];
}

<div class="container py-5 fade-up d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="bg-surface border border-secondary border-opacity-25 rounded-0 p-5" style="width: 100%; max-width: 440px;">
        
        <div class="text-center mb-5">
            <h2 class="display-6 brand-font fw-bold text-white mb-2">@Localizer["CreateAccount"]</h2>
            <p class="text-secondary text-uppercase ls-1 small mb-0">Join the Collective</p>
        </div>
        
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small font-monospace mb-4"></div>

            <div class="mb-4">
                <label class="form-label text-secondary text-uppercase ls-1" style="font-size: 0.7rem;">@Localizer["Email"]</label>
                <input asp-for="Input.Email" class="form-control bg-transparent border-secondary border-opacity-25 text-white rounded-0 shadow-none focus-border-accent py-3" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="text-danger small font-monospace mt-1 d-block"></span>
            </div>

            <div class="mb-4">
                <label class="form-label text-secondary text-uppercase ls-1" style="font-size: 0.7rem;">@Localizer["Password"]</label>
                <div class="position-relative">
                    <input asp-for="Input.Password" class="form-control bg-transparent border-secondary border-opacity-25 text-white rounded-0 shadow-none focus-border-accent py-3 pe-5" placeholder="••••••••" type="password" oninput="toggleEyeVisibility(this)" />
                    <button type="button" class="btn text-secondary text-decoration-none position-absolute top-50 end-0 translate-middle-y d-none shadow-none pe-3 border-0 bg-transparent" onclick="togglePasswordVisibility(this)" tabindex="-1">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Input.Password" class="text-danger small font-monospace mt-1 d-block"></span>
            </div>

            <div class="mb-5">
                <label class="form-label text-secondary text-uppercase ls-1" style="font-size: 0.7rem;">@Localizer["ConfirmPassword"]</label>
                <div class="position-relative">
                    <input asp-for="Input.ConfirmPassword" class="form-control bg-transparent border-secondary border-opacity-25 text-white rounded-0 shadow-none focus-border-accent py-3 pe-5" placeholder="••••••••" type="password" oninput="toggleEyeVisibility(this)" />
                    <button type="button" class="btn text-secondary text-decoration-none position-absolute top-50 end-0 translate-middle-y d-none shadow-none pe-3 border-0 bg-transparent" onclick="togglePasswordVisibility(this)" tabindex="-1">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small font-monospace mt-1 d-block"></span>
            </div>

            <button type="submit" class="btn btn-luxury w-100 py-3 text-uppercase ls-1 mb-4" style="font-size: 0.8rem;">
                <i class="fa-solid fa-user-plus me-2"></i> @Localizer["Register"]
            </button>

            <div class="text-center pt-4 border-top border-secondary border-opacity-25">
                <span class="text-secondary text-uppercase ls-1" style="font-size: 0.65rem;">@Localizer["AlreadyHaveAccount"]</span><br />
                <a asp-page="./Login" class="text-white fw-bold text-decoration-none text-uppercase ls-1 mt-2 d-inline-block" style="font-size: 0.75rem;">
                    @Localizer["LogInHere"]
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleEyeVisibility(input) {
            const btn = input.nextElementSibling;
            if (input.value.length > 0) {
                btn.classList.remove('d-none');
            } else {
                btn.classList.add('d-none');
                input.type = 'password';
                btn.innerHTML = '<i class="fas fa-eye"></i>';
            }
        }
        function togglePasswordVisibility(btn) {
            const input = btn.previousElementSibling;
            if (input.type === 'password') {
                input.type = 'text';
                btn.innerHTML = '<i class="fas fa-eye-slash text-white"></i>';
            } else {
                input.type = 'password';
                btn.innerHTML = '<i class="fas fa-eye"></i>';
            }
        }
    </script>
}