@model VirtualHair.Models.AdminDashboardViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["AdminPanel"];
}

<div class="container py-5 fade-up">
    <!-- Header -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 pb-4 border-bottom border-light border-opacity-10">
        <div>
            <h2 class="display-6 brand-font fw-bold text-white mb-2">@Localizer["AdminPanel"]</h2>
            <p class="text-secondary text-uppercase ls-1 small mb-0">@Localizer["PlatformAccessControl"]</p>
        </div>
        <div class="mt-4 mt-md-0 d-flex gap-3">
            <a asp-action="Users" class="btn btn-outline-secondary px-4 py-2">
                <i class="fa-solid fa-users me-2"></i> @Localizer["UserRegistry"]
            </a>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <!-- Quick Links -->
        <div class="col-lg-3">
            <h6 class="fw-bold mb-4 text-uppercase ls-1 text-white border-start border-3 px-3" style="border-color: var(--accent-color) !important;">
                @Localizer["Management"]
            </h6>
            <div class="d-flex flex-column gap-2 mb-4">
                <a asp-controller="Hairstyles" asp-action="Index" class="btn btn-ghost text-start py-3 border border-secondary border-opacity-25 w-100 rounded-0">
                    <i class="fa-solid fa-scissors me-3" style="color: var(--accent-color);"></i> @Localizer["Hairstyles"]
                </a>
                <a asp-controller="FacialHairs" asp-action="Index" class="btn btn-ghost text-start py-3 border border-secondary border-opacity-25 w-100 rounded-0">
                    <i class="fa-solid fa-beard me-3" style="color: var(--accent-color);"></i> @Localizer["FacialHair"]
                </a>
                <a asp-action="Users" class="btn btn-ghost text-start py-3 border border-secondary border-opacity-25 w-100 rounded-0">
                    <i class="fa-solid fa-users-gear me-3" style="color: var(--accent-color);"></i> @Localizer["UserRoles"]
                </a>
                <a asp-action="Posts" class="btn btn-ghost text-start py-3 border border-secondary border-opacity-25 w-100 rounded-0">
                    <i class="fa-solid fa-newspaper me-3" style="color: var(--accent-color);"></i> @Localizer["ActivePosts"]
                </a>
            </div>
        </div>

        <!-- Dashboard Stats -->
        <div class="col-lg-9">
            <h6 class="fw-bold mb-4 text-uppercase ls-1 text-white border-start border-3 px-3" style="border-color: var(--accent-color) !important;">
                @Localizer["PlatformStatistics"]
            </h6>
            
            <div class="row g-3 mb-5">
                <div class="col-md-4 col-sm-6">
                    <div class="bg-surface border border-secondary border-opacity-25 p-4 rounded-0 position-relative h-100">
                        <small class="text-secondary text-uppercase ls-1 d-block mb-2" style="font-size: 0.65rem;">@Localizer["TotalUsers"]</small>
                        <h3 class="display-5 fw-bold text-white mb-0">@Model.TotalUsers</h3>
                        <i class="fa-solid fa-user-group position-absolute opacity-10 fs-1" style="bottom: 1rem; right: 1.5rem; color: var(--accent-color);"></i>
                    </div>
                </div>
                <div class="col-md-4 col-sm-6">
                    <div class="bg-surface border border-secondary border-opacity-25 p-4 rounded-0 position-relative h-100">
                        <small class="text-secondary text-uppercase ls-1 d-block mb-2" style="font-size: 0.65rem;">@Localizer["TotalHairstyles"]</small>
                        <h3 class="display-5 fw-bold text-white mb-0">@Model.TotalHairstyles</h3>
                        <i class="fa-solid fa-scissors position-absolute opacity-10 fs-1" style="bottom: 1rem; right: 1.5rem; color: var(--accent-color);"></i>
                    </div>
                </div>
                <div class="col-md-4 col-sm-6">
                    <div class="bg-surface border border-secondary border-opacity-25 p-4 rounded-0 position-relative h-100">
                        <small class="text-secondary text-uppercase ls-1 d-block mb-2" style="font-size: 0.65rem;">@Localizer["FacialHair"]</small>
                        <h3 class="display-5 fw-bold text-white mb-0">@Model.TotalFacialHairs</h3>
                        <i class="fa-solid fa-beard position-absolute opacity-10 fs-1" style="bottom: 1rem; right: 1.5rem; color: var(--accent-color);"></i>
                    </div>
                </div>
                <div class="col-md-4 col-sm-6">
                    <div class="bg-surface border border-secondary border-opacity-25 p-4 rounded-0 position-relative h-100">
                        <small class="text-secondary text-uppercase ls-1 d-block mb-2" style="font-size: 0.65rem;">@Localizer["CommunityPosts"]</small>
                        <h3 class="display-5 fw-bold text-white mb-0">@Model.TotalPosts</h3>
                        <i class="fa-solid fa-share-nodes position-absolute opacity-10 fs-1" style="bottom: 1rem; right: 1.5rem; color: var(--accent-color);"></i>
                    </div>
                </div>
                <div class="col-md-4 col-sm-6">
                    <div class="bg-surface border border-secondary border-opacity-25 p-4 rounded-0 position-relative h-100">
                        <small class="text-secondary text-uppercase ls-1 d-block mb-2" style="font-size: 0.65rem;">@Localizer["DirectMessaging"]</small>
                        <h3 class="display-5 fw-bold text-white mb-0">@Model.TotalMessages</h3>
                        <i class="fa-solid fa-envelope position-absolute opacity-10 fs-1" style="bottom: 1rem; right: 1.5rem; color: var(--accent-color);"></i>
                    </div>
                </div>
                <div class="col-md-4 col-sm-6">
                    <div class="bg-surface border border-secondary border-opacity-25 p-4 rounded-0 position-relative h-100">
                        <small class="text-secondary text-uppercase ls-1 d-block mb-2" style="font-size: 0.65rem;">@Localizer["GalleryPhotos"]</small>
                        <h3 class="display-5 fw-bold text-white mb-0">@Model.TotalPhotos</h3>
                        <i class="fa-solid fa-camera position-absolute opacity-10 fs-1" style="bottom: 1rem; right: 1.5rem; color: var(--accent-color);"></i>
                    </div>
                </div>
            </div>

            <!-- Activity Log -->
            <h6 class="fw-bold mb-4 text-uppercase ls-1 text-white border-start border-3 px-3" style="border-color: var(--accent-color) !important;">
                @Localizer["RecentUsers"]
            </h6>
            
            <div class="bg-surface border border-secondary border-opacity-25 rounded-0">
                @if (!Model.RecentUsers.Any())
                {
                    <div class="p-5 text-center text-secondary">
                        <i class="fa-solid fa-ghost fs-1 mb-3 opacity-25"></i>
                        <p class="mb-0 text-uppercase ls-1 small">@Localizer["NoRecentUsers"]</p>
                    </div>
                }
                else
                {
                    <ul class="list-group list-group-flush rounded-0 bg-transparent">
                        @foreach (var user in Model.RecentUsers)
                        {
                            <li class="list-group-item bg-transparent text-white border-secondary border-opacity-25 p-4 d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="d-flex align-items-center justify-content-center bg-black border border-secondary border-opacity-50" style="width: 40px; height: 40px; border-radius: 5px;">
                                        <i class="fa-solid fa-user text-secondary"></i>
                                    </div>
                                    <div>
                                        <p class="mb-0 fw-bold">@user.Email</p>
                                        <small class="text-secondary text-uppercase ls-1" style="font-size: 0.65rem;">New user joined</small>
                                    </div>
                                </div>
                                <div>
                                    <a asp-action="Users" class="btn btn-ghost px-3 py-1 text-uppercase ls-1 small" style="font-size: 0.7rem;">View</a>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
