@model IEnumerable<VirtualHair.Models.Post>
@{
    ViewData["Title"] = "Post Moderation";
}

<div class="container py-5 fade-up">
    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-5 border-bottom border-light border-opacity-10 pb-4">
        <div>
            <h2 class="display-6 brand-font fw-bold text-white mb-2">Content Moderation</h2>
            <p class="text-secondary text-uppercase ls-1 small mb-0">Platform Posts Control</p>
        </div>
        <a asp-action="Index" class="btn btn-ghost px-4 py-2 border border-secondary border-opacity-25 rounded-0 text-uppercase ls-1" style="font-size: 0.75rem;">
            <i class="fa-solid fa-arrow-left me-2"></i> Dashboard
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-0 mb-4 ls-1 small text-uppercase" role="alert" style="background: rgba(25, 135, 84, 0.05); border: 1px solid rgba(25, 135, 84, 0.2); color: #20c997;">
            <i class="fa-solid fa-check-circle me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="bg-surface border border-secondary border-opacity-25 rounded-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent;">
                <thead>
                    <tr class="text-uppercase ls-1 border-bottom border-secondary border-opacity-25" style="font-size: 0.7rem;">
                        <th class="py-3 px-4 text-secondary font-monospace" style="width: 120px;">Asset</th>
                        <th class="py-3 text-secondary font-monospace">Identifier</th>
                        <th class="py-3 text-secondary font-monospace">Caption</th>
                        <th class="py-3 text-secondary font-monospace">Timestamp</th>
                        <th class="py-3 px-4 text-end text-secondary font-monospace">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var post in Model)
                    {
                        <tr class="border-bottom border-secondary border-opacity-10">
                            <td class="px-4 py-3">
                                <div class="bg-black border border-secondary border-opacity-25 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                    <img src="@post.ImagePath" class="w-100 h-100 object-fit-cover" alt="Post" />
                                </div>
                            </td>
                            <td class="py-3">
                                <div class="fw-bold text-white fs-6">@post.UserId</div>
                            </td>
                            <td class="py-3">
                                <div class="text-truncate text-secondary" style="max-width: 250px; font-size: 0.85rem;">
                                    @(string.IsNullOrEmpty(post.Description) ? "—" : post.Description)
                                </div>
                            </td>
                            <td class="py-3 text-secondary small">
                                @post.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                            </td>
                            <td class="px-4 py-3 text-end">
                                <form asp-action="DeletePost" asp-route-id="@post.Id" method="post" onsubmit="return confirm('Confirm deletion?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-ghost border-danger border-opacity-50 text-danger rounded-0 py-2 px-3 text-uppercase ls-1" style="font-size: 0.7rem; background: rgba(220, 53, 69, 0.05);">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-secondary text-uppercase ls-1 small">
                                <i class="fa-solid fa-folder-open mb-3 fs-3 opacity-50 d-block"></i>
                                No content to moderate
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
