@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityUser>
@{
    ViewData["Title"] = "User Management";
}

<div class="container py-5 fade-up">
    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-5 border-bottom border-light border-opacity-10 pb-4">
        <div>
            <h2 class="display-6 brand-font fw-bold text-white mb-2">User Registry</h2>
            <p class="text-secondary text-uppercase ls-1 small mb-0">Platform Access Control</p>
        </div>
        <a asp-action="Index" class="btn btn-ghost px-4 py-2 border border-secondary border-opacity-25 rounded-0 text-uppercase ls-1" style="font-size: 0.75rem;">
            <i class="fa-solid fa-arrow-left me-2"></i> Dashboard
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-0 mb-4 ls-1 small text-uppercase" role="alert" style="background: rgba(25, 135, 84, 0.05); border: 1px solid rgba(25, 135, 84, 0.2); color: #20c997;">
            <i class="fa-solid fa-check-circle me-2"></i> @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-0 mb-4 ls-1 small text-uppercase" role="alert" style="background: rgba(220, 53, 69, 0.05); border: 1px solid rgba(220, 53, 69, 0.2); color: #ef4444;">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]
        </div>
    }

    <div class="bg-surface border border-secondary border-opacity-25 rounded-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent;">
                <thead>
                    <tr class="text-uppercase ls-1 border-bottom border-secondary border-opacity-25" style="font-size: 0.7rem;">
                        <th class="py-3 px-4 text-secondary font-monospace" style="width: 250px;">Account Name</th>
                        <th class="py-3 text-secondary font-monospace">Recovery Address</th>
                        <th class="py-3 text-secondary font-monospace">UUID</th>
                        <th class="py-3 px-4 text-end text-secondary font-monospace">Security Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr class="border-bottom border-secondary border-opacity-10">
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-black border border-secondary border-opacity-25 text-secondary d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; font-size: 1.2rem; filter: grayscale(100%);">
                                        <i class="fa-solid fa-user-astronaut"></i>
                                    </div>
                                    <div class="fw-bold text-white fs-6">@user.UserName</div>
                                </div>
                            </td>
                            <td class="py-3">
                                <span class="text-white opacity-75">@user.Email</span>
                            </td>
                            <td class="py-3">
                                <span class="text-secondary small font-monospace">@user.Id</span>
                            </td>
                            <td class="px-4 py-3 text-end">
                                <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" onsubmit="return confirm('Confirm destructive action: delete user configuration permanentally?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-ghost border-danger border-opacity-50 text-danger rounded-0 py-2 px-3 text-uppercase ls-1" style="font-size: 0.7rem; background: rgba(220, 53, 69, 0.05);">
                                        Revoke Access
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-secondary text-uppercase ls-1 small">
                                <i class="fa-solid fa-user-xmark mb-3 fs-3 opacity-50 d-block"></i>
                                No active registries
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
