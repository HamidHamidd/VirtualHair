@model VirtualHair.Models.FacialHair
@{
    ViewData["Title"] = "Delete Facial Hair";
}

<div class="container py-5 fade-up">
    <div class="mx-auto" style="max-width: 600px;">
        <div class="bg-surface border border-secondary border-opacity-25 rounded-0 p-5">
            <div class="text-center mb-5">
                <div class="d-inline-flex align-items-center justify-content-center border border-danger border-opacity-50 text-danger mb-4" style="width: 60px; height: 60px; border-radius: 0; background: rgba(220, 53, 69, 0.05);">
                    <i class="fa-solid fa-triangle-exclamation fs-3"></i>
                </div>
                <h3 class="display-6 brand-font fw-bold text-white mb-2">Delete Validation</h3>
                <p class="text-secondary small text-uppercase ls-1">Permanent Data Removal</p>
                <div class="alert mt-4 rounded-0 small text-uppercase ls-1 d-inline-block px-4 py-2" style="background: rgba(220, 53, 69, 0.05); border: 1px solid rgba(220, 53, 69, 0.2); color: #ef4444;">
                    Warning: This action cannot be reversed
                </div>
            </div>

            <div class="bg-black border border-secondary border-opacity-25 p-4 mb-5">
                <div class="row g-4 align-items-center">
                    <div class="col-sm-5">
                        <div class="border border-secondary border-opacity-10 ratio ratio-1x1 bg-surface d-flex align-items-center justify-content-center rounded-0">
                            @if (Model.ImageData != null)
                            {
                                <img src="/FacialHairs/Image/@Model.Id" class="w-100 h-100 object-fit-cover" alt="@Model.Name" />
                            }
                            else
                            {
                                <i class="fa-solid fa-image text-muted opacity-50 fs-1"></i>
                            }
                        </div>
                    </div>
                    <div class="col-sm-7">
                        <div class="d-flex flex-column gap-3">
                            <div>
                                <div class="text-secondary small text-uppercase ls-1" style="font-size: 0.65rem;">Facial Hair Data</div>
                                <div class="fw-bold text-white fs-5">@Model.Name</div>
                            </div>
                            <div>
                                <div class="text-secondary small text-uppercase ls-1" style="font-size: 0.65rem;">Default Hex Value</div>
                                <div class="text-white">
                                    <span class="d-inline-block rounded-circle me-2 border border-secondary border-opacity-50" style="width: 12px; height: 12px; background-color: @Model.DefaultColorHex;"></span>
                                    @Model.DefaultColorHex
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex flex-column flex-sm-row gap-3">
                    <button type="submit" class="btn btn-ghost border-danger border-opacity-50 text-danger flex-grow-1 py-3 text-uppercase ls-1 rounded-0" style="font-size: 0.75rem; background: rgba(220, 53, 69, 0.05);">
                        <i class="fa-solid fa-trash-can me-2"></i> Confirm Deletion
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary flex-grow-1 py-3 text-uppercase ls-1 rounded-0" style="font-size: 0.75rem;">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
