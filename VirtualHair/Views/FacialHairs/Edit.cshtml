@model VirtualHair.Models.FacialHair
@{
    ViewData["Title"] = "Edit Facial Hair";
}

<div class="container py-5 fade-up d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="bg-surface border border-secondary border-opacity-25 rounded-0 p-5" style="width: 100%; max-width: 600px;">
        <div class="text-center mb-5">
            <h2 class="display-6 brand-font fw-bold text-white mb-2">Edit Facial Hair</h2>
            <p class="text-secondary text-uppercase ls-1 small mb-0">Modify Dictionary Entry</p>
        </div>

        <form asp-action="Edit" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />

            <!-- Existing Image Preview -->
            @if (Model.ImageData != null)
            {
                <div class="mb-5 d-flex flex-column align-items-center">
                    <span class="text-secondary text-uppercase ls-1 d-block mb-3" style="font-size: 0.7rem;">Current Asset</span>
                    <div class="border border-secondary border-opacity-25 bg-black d-flex align-items-center justify-content-center rounded-0 p-2" style="width: 140px; height: 140px;">
                        <img src="/FacialHairs/Image/@Model.Id" alt="preview" class="w-100 h-100 object-fit-cover" />
                    </div>
                </div>
            }

            <div class="mb-4">
                <label asp-for="Name" class="form-label text-secondary text-uppercase ls-1" style="font-size: 0.7rem;"></label>
                <input asp-for="Name" class="form-control bg-transparent border-secondary border-opacity-25 text-white rounded-0 shadow-none focus-border-accent py-3" />
                <span asp-validation-for="Name" class="text-danger small font-monospace mt-1 d-block"></span>
            </div>

            <div class="mb-4">
                <label asp-for="DefaultColorHex" class="form-label text-secondary text-uppercase ls-1" style="font-size: 0.7rem;"></label>
                <input asp-for="DefaultColorHex" type="color" class="form-control form-control-color bg-transparent border-secondary border-opacity-25 rounded-0 shadow-none p-1" style="height: 50px; width: 100%;" />
            </div>

            <div class="mb-5">
                <label class="form-label text-secondary text-uppercase ls-1" style="font-size: 0.7rem;">Upload Alternate Image</label>
                <input asp-for="ImageFile" type="file" class="form-control bg-transparent border-secondary border-opacity-25 text-white rounded-0 shadow-none focus-border-accent py-3" />
            </div>

            <div class="d-flex flex-column flex-sm-row gap-3 pt-4 border-top border-secondary border-opacity-25">
                <button type="submit" class="btn btn-luxury flex-grow-1 py-3 text-uppercase ls-1" style="font-size: 0.8rem;">
                    <i class="fa-solid fa-floppy-disk me-2"></i> Update Asset
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary flex-grow-1 py-3 text-uppercase ls-1 rounded-0" style="font-size: 0.8rem;">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
