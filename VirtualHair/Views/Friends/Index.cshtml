@{
    ViewData["Title"] = "Friends";
    var myFriends = ViewBag.Friends as List<Microsoft.AspNetCore.Identity.IdentityUser>;
    var suggestions = ViewBag.Suggestions as List<Microsoft.AspNetCore.Identity.IdentityUser>;
    var sentRequests = ViewBag.SentRequests as List<Microsoft.AspNetCore.Identity.IdentityUser>;
    var receivedRequests = ViewBag.ReceivedRequests as List<Microsoft.AspNetCore.Identity.IdentityUser>;
}

<div class="container-fluid py-4 fade-up" style="@(Context.Request.Query.ContainsKey("embed") ? "min-height: 100vh;" : "")">
    <div class="row mb-5 align-items-center border-bottom border-light border-opacity-10 pb-4">
        <div class="col-md-6">
            <h2 class="display-6 brand-font fw-bold text-white mb-2">Community</h2>
            <p class="text-secondary text-uppercase ls-1 small mb-0">Platform Connections</p>
        </div>
        <div class="col-md-6 text-md-end mt-4 mt-md-0">
            <div class="input-group border border-secondary border-opacity-25 rounded-0 overflow-hidden ms-auto shadow-sm" style="max-width: 300px; background: var(--bg-surface);">
                <span class="input-group-text bg-transparent border-0 px-3 py-2 text-secondary">
                    <i class="fa-solid fa-magnifying-glass small"></i>
                </span>
                <input type="text" id="friendSearch" class="form-control border-0 bg-transparent text-white shadow-none focus-none py-2" placeholder="Search identities..." style="font-size: 0.85rem; letter-spacing: 0.05em;">
            </div>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <ul class="nav nav-pills custom-tabs mb-5 border-bottom border-secondary border-opacity-25" id="friendsTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active bg-transparent rounded-0 text-uppercase ls-1 py-3 px-4" id="friends-tab" data-bs-toggle="tab" data-bs-target="#friends" type="button" role="tab" style="font-size: 0.75rem;">
                All Links (@myFriends?.Count)
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link bg-transparent rounded-0 text-uppercase ls-1 py-3 px-4" id="requests-tab" data-bs-toggle="tab" data-bs-target="#requests" type="button" role="tab" style="font-size: 0.75rem;">
                Pending
                @if(receivedRequests?.Count > 0)
                {
                    <span class="badge rounded-0 ms-2" style="background: var(--accent-color); color: #000;">@receivedRequests.Count</span>
                }
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link bg-transparent rounded-0 text-uppercase ls-1 py-3 px-4" id="discover-tab" data-bs-toggle="tab" data-bs-target="#discover" type="button" role="tab" style="font-size: 0.75rem;">
                Discover
            </button>
        </li>
    </ul>

    <div class="tab-content" id="friendsTabContent">
        <!-- My Friends Tab -->
        <div class="tab-pane fade show active" id="friends" role="tabpanel">
            <div class="row g-4 user-grid">
                @if (myFriends != null && myFriends.Any())
                {
                    foreach (var user in myFriends)
                    {
                        <div class="col-12 col-md-6 col-lg-4 user-card-item">
                            <div class="bg-surface border border-secondary border-opacity-25 rounded-0 h-100 p-4 transition-all hover-border-accent">
                                <div class="d-flex align-items-center">
                                    <div class="bg-black border border-secondary border-opacity-50" style="width: 50px; height: 50px;">
                                        <img src="/Profile/GetPhoto?userId=@user.Id" class="w-100 h-100 object-fit-cover" alt="Avatar" onerror="this.src='https://ui-avatars.com/api/?name=@user.UserName&background=000&color=d4af37'">
                                    </div>
                                    <div class="ms-3 flex-grow-1 overflow-hidden">
                                        <h6 class="mb-0 fw-bold text-white ls-1 text-truncate searchable-name" style="font-size: 0.9rem;">@user.UserName</h6>
                                        <small class="text-secondary text-uppercase font-monospace" style="font-size: 0.65rem;">Active Link</small>
                                    </div>
                                    <div class="ms-2">
                                        <button onclick="removeFriend('@user.Id')" class="btn btn-ghost border-danger border-opacity-50 text-danger rounded-0 px-3 py-2 text-uppercase ls-1" style="font-size: 0.65rem; background: rgba(220, 53, 69, 0.05);" title="Sever Link">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5 my-5 border border-secondary border-opacity-10 bg-surface">
                        <i class="fa-solid fa-network-wired fa-2x text-muted mb-4 opacity-50"></i>
                        <h4 class="fw-bold brand-font text-white mb-2">No Verified Links</h4>
                        <p class="text-secondary small ls-1 text-uppercase mb-0">Use the Discovery protocol to establish connections.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Requests Tab -->
        <div class="tab-pane fade" id="requests" role="tabpanel">
            
            @if((receivedRequests == null || !receivedRequests.Any()) && (sentRequests == null || !sentRequests.Any()))
            {
                <div class="col-12 text-center py-5 my-5 border border-secondary border-opacity-10 bg-surface">
                    <i class="fa-solid fa-satellite fa-2x text-muted mb-4 opacity-50"></i>
                    <h5 class="fw-bold brand-font text-white mb-2">No Signal Detected</h5>
                    <p class="text-secondary small ls-1 text-uppercase mb-0">No pending requests inbound or outbound.</p>
                </div>
            }

            @if (receivedRequests != null && receivedRequests.Any())
            {
                <h6 class="fw-bold mb-4 text-uppercase ls-1 text-white border-start border-3 px-3 section-title" style="border-color: var(--accent-color) !important; font-size: 0.8rem;">
                    Inbound Requests
                </h6>
                <div class="row g-4 user-grid mb-5">
                    @foreach (var user in receivedRequests)
                    {
                        <div class="col-12 col-md-6 col-lg-4 user-card-item">
                            <div class="bg-surface border border-secondary border-opacity-25 border-start border-3 rounded-0 h-100 p-4 transition-all" style="border-left-color: var(--accent-color) !important;">
                                <div class="d-flex align-items-center mb-4">
                                    <div class="bg-black border border-secondary border-opacity-50" style="width: 50px; height: 50px;">
                                        <img src="/Profile/GetPhoto?userId=@user.Id" class="w-100 h-100 object-fit-cover" alt="Avatar" onerror="this.src='https://ui-avatars.com/api/?name=@user.UserName&background=000&color=d4af37'">
                                    </div>
                                    <div class="ms-3 flex-grow-1 overflow-hidden">
                                        <h6 class="mb-0 fw-bold text-white ls-1 text-truncate searchable-name" style="font-size: 0.9rem;">@user.UserName</h6>
                                        <small class="text-secondary text-uppercase font-monospace" style="font-size: 0.65rem;">Awaiting Verification</small>
                                    </div>
                                </div>
                                <div class="d-flex gap-2 w-100 mt-auto border-top border-secondary border-opacity-25 pt-3">
                                    <button onclick="acceptFriend('@user.Id')" class="btn btn-luxury flex-grow-1 py-2 text-uppercase ls-1" style="font-size: 0.7rem;">Verify</button>
                                    <button onclick="removeFriend('@user.Id')" class="btn btn-ghost border border-secondary border-opacity-25 text-secondary flex-grow-1 py-2 text-uppercase ls-1" style="font-size: 0.7rem;">Reject</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (sentRequests != null && sentRequests.Any())
            {
                <h6 class="fw-bold mb-4 text-uppercase ls-1 text-white border-start border-3 px-3 section-title" style="border-color: var(--text-muted) !important; font-size: 0.8rem;">
                    Outbound Requests
                </h6>
                <div class="row g-4 user-grid mb-5">
                    @foreach (var user in sentRequests)
                    {
                        <div class="col-12 col-md-6 col-lg-4 user-card-item">
                            <div class="bg-surface border border-secondary border-opacity-25 rounded-0 h-100 p-4 transition-all">
                                <div class="d-flex align-items-center">
                                    <div class="bg-black border border-secondary border-opacity-50 opacity-50" style="width: 50px; height: 50px;">
                                        <img src="/Profile/GetPhoto?userId=@user.Id" class="w-100 h-100 object-fit-cover filter-grayscale" alt="Avatar" onerror="this.src='https://ui-avatars.com/api/?name=@user.UserName&background=000&color=d4af37'">
                                    </div>
                                    <div class="ms-3 flex-grow-1 overflow-hidden">
                                        <h6 class="mb-0 fw-bold text-white opacity-75 ls-1 text-truncate searchable-name" style="font-size: 0.9rem;">@user.UserName</h6>
                                        <small class="text-secondary text-uppercase font-monospace" style="font-size: 0.65rem;">Signal Transmitted</small>
                                    </div>
                                    <div class="ms-2">
                                        <button onclick="removeFriend('@user.Id')" class="btn btn-ghost border-danger border-opacity-50 text-danger rounded-0 px-3 py-2 text-uppercase ls-1" style="font-size: 0.65rem; background: rgba(220, 53, 69, 0.05);" title="Abort">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Discover Tab -->
        <div class="tab-pane fade" id="discover" role="tabpanel">
            <div class="row g-4 user-grid">
                @if (suggestions != null && suggestions.Any())
                {
                    foreach (var user in suggestions)
                    {
                        <div class="col-12 col-md-6 col-lg-4 user-card-item">
                            <div class="bg-surface border border-secondary border-opacity-25 rounded-0 h-100 p-4 transition-all d-flex flex-column align-items-center justify-content-center text-center">
                                <div class="bg-black border border-secondary border-opacity-50 mb-4" style="width: 80px; height: 80px; padding: 4px;">
                                    <img src="/Profile/GetPhoto?userId=@user.Id" class="w-100 h-100 object-fit-cover" alt="Avatar" onerror="this.src='https://ui-avatars.com/api/?name=@user.UserName&background=000&color=d4af37'">
                                </div>
                                <h5 class="fw-bold mb-1 text-truncate w-100 searchable-name text-white font-monospace" style="font-size: 0.9rem;">@user.UserName</h5>
                                <small class="text-secondary text-uppercase ls-1 mb-4" style="font-size: 0.65rem;">Unverified Entity</small>
                                
                                <button onclick="addFriend('@user.Id')" class="btn btn-outline-light rounded-0 w-100 py-2 text-uppercase ls-1 mt-auto mx-auto" style="font-size: 0.75rem;">
                                    <i class="fa-solid fa-wifi me-2"></i> Transmit Signal
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5 my-5 border border-secondary border-opacity-10 bg-surface">
                        <i class="fa-solid fa-radar fa-2x text-muted mb-4 opacity-50"></i>
                        <h4 class="fw-bold brand-font text-white mb-2">No Targets Found</h4>
                        <p class="text-secondary small ls-1 text-uppercase mb-0">The discovery radar is currently clear.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .custom-tabs .nav-link {
        color: var(--text-muted);
        border: 1px solid transparent;
        border-bottom: 2px solid transparent;
        transition: all 0.2s ease;
    }
    .custom-tabs .nav-link:hover {
        color: var(--text-primary);
    }
    .custom-tabs .nav-link.active {
        color: var(--text-primary);
        border-bottom-color: var(--accent-color);
        background: var(--border-subtle) !important;
    }
    .hover-border-accent:hover {
        border-color: rgba(255,255,255,0.2) !important;
    }
    .filter-grayscale {
        filter: grayscale(100%);
    }
</style>

@section Scripts {
    <script>
        // Filters
        document.getElementById('friendSearch').addEventListener('input', function() {
            const query = this.value.toLowerCase();
            document.querySelectorAll('.user-card-item').forEach(card => {
                const name = card.querySelector('.searchable-name').textContent.toLowerCase();
                if (name.includes(query)) {
                    card.classList.remove('d-none');
                } else {
                    card.classList.add('d-none');
                }
            });
        });

        async function addFriend(targetId) {
            await fetch('/Friends/AddFriend', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `targetId=${targetId}`
            });
            location.reload();
        }

        async function acceptFriend(targetId) {
            await fetch('/Friends/AcceptFriend', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `targetId=${targetId}`
            });
            location.reload();
        }

        async function removeFriend(targetId) {
            if(!confirm("Are you sure?")) return;
            await fetch('/Friends/RemoveFriend', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `targetId=${targetId}`
            });
            location.reload();
        }
    </script>
}
