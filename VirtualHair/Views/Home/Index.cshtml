@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = "VirtualHair";
    var hairstyles = ViewBag.Hairstyles as List<VirtualHair.Models.Hairstyle>;
    var facialHairs = ViewBag.FacialHairs as List<VirtualHair.Models.FacialHair>;
}

<section class="d-flex flex-column justify-content-center align-items-center text-center fade-up" style="min-height: 85vh;">
    <div class="container" style="max-width: 900px;">
        <span class="badge-editorial mb-4">The New Standard</span>
        <h1 class="display-1 brand-font mb-4 text-gradient" style="letter-spacing: -0.03em;">
            Liquid Obsidian
        </h1>
        <p class="lead mb-5 mx-auto" style="color: var(--text-secondary); font-size: 1.15rem; max-width: 600px; font-weight: 300;">
            @Localizer["UploadDescription"] Experience a world-class AI transformation engine wrapped in stunningly minimal design.
        </p>
        
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <a href="#preview-tool" class="btn btn-luxury px-5">
                @Localizer["TryNow"]
            </a>
        }
        else
        {
             <div class="d-flex justify-content-center gap-4">
                 <a href="/Identity/Account/Login" class="btn btn-ghost px-5">
                     @Localizer["LogInToTry"]
                 </a>
                 <a href="/Identity/Account/Register" class="btn btn-luxury px-5">
                     Discover <i class="fa-solid fa-arrow-right ms-2 position-relative" style="top: 1px;"></i>
                 </a>
             </div>
        }
    </div>
</section>

@if (User.Identity != null && User.Identity.IsAuthenticated)
{
<div id="preview-tool" class="py-5 bg-black">
    <div class="container reveal" style="max-width: 1400px;">
        <div class="text-center mb-5 pb-3">
            <h2 class="display-4 brand-font mb-3">@Localizer["TryYourLook"]</h2>
            <p class="text-uppercase letter-spacing-1 small" style="color: var(--text-secondary);">@Localizer["UploadDescription"]</p>
        </div>

        <div class="row g-0 border border-secondary border-opacity-25 reveal reveal-delayed">
            <!-- LEFT: Canvas + Upload -->
            <div class="col-lg-7 border-end border-secondary border-opacity-25 bg-surface">
                <div class="d-flex flex-column h-100 position-relative p-4">
                    <div class="mb-4">
                        <label for="imageUpload" class="d-flex flex-column align-items-center justify-content-center py-5 w-100" style="border: 1px dashed var(--border-focus); cursor: pointer; transition: all 0.3s ease;">
                            <span class="text-uppercase letter-spacing-1 small" style="color: var(--accent-color);">@Localizer["UploadFacePhoto"]</span>
                            <input type="file" id="imageUpload" accept="image/*" class="d-none" />
                        </label>
                    </div>

                    <div class="position-relative flex-grow-1 d-flex align-items-center justify-content-center overflow-hidden bg-black" style="min-height: 500px; border: 1px solid var(--border-subtle);">
                        <canvas id="previewCanvas" class="w-100 h-100 object-fit-contain"></canvas>
                        
                        <div id="aiDetectorStatus" class="position-absolute top-0 start-0 m-3 px-3 py-2 small fw-bold text-black bg-white" style="opacity: 0.9; font-size: 0.75rem; text-transform: uppercase;">
                            <i class="fa-solid fa-robot fa-spin me-2"></i>@Localizer["Analyzing"]
                        </div>
                        
                        <div id="aiSuccessStatus" class="position-absolute top-0 start-0 m-3 px-3 py-2 small fw-bold text-black d-none" style="background: var(--accent-color); font-size: 0.75rem; text-transform: uppercase;">
                            <i class="fa-solid fa-check me-2"></i> @Localizer["FaceDetected"]
                        </div>
                        
                        <button id="reScanFace" class="btn btn-ghost btn-sm position-absolute bottom-0 start-0 m-3 px-3 py-2" style="font-size: 0.65rem;">
                            Re-scan Focus
                        </button>
                    </div>
                </div>
            </div>

            <!-- RIGHT: Thumbnails + Controls -->
            <div class="col-lg-5">
                <div class="editorial-card h-100 border-0 p-4 p-md-5 d-flex flex-column">
                    
                    <!-- Styles selection -->
                    <div class="mb-5">
                        <h6 class="text-uppercase fw-bold small text-muted mb-4 letter-spacing-1">
                            @Localizer["Hairstyles"]
                        </h6>
                        <div class="d-flex gap-3 overflow-x-auto pb-3" style="scrollbar-width: thin;">
                            <div class="text-center flex-shrink-0" onclick="selectNone('hairstyle')" style="width: 70px; cursor: pointer;">
                                <div class="d-flex align-items-center justify-content-center mb-2" style="width: 100%; aspect-ratio: 4/5; border: 1px solid var(--border-subtle);">
                                    <i class="fa-solid fa-ban text-muted"></i>
                                </div>
                                <span class="small text-muted text-uppercase" style="font-size: 0.65rem;">None</span>
                            </div>
                            @if (hairstyles != null)
                            {
                                @foreach (var h in hairstyles)
                                {
                                    <div class="text-center flex-shrink-0 style-thumb-container" style="width: 70px; cursor: pointer;">
                                        <div class="gallery-img-wrapper mb-2 border border-secondary border-opacity-10" style="aspect-ratio: 4/5;">
                                            <img src="/Hairstyles/Image/@h.Id"
                                                 alt="@h.Name"
                                                 class="style-thumb gallery-img"
                                                 data-type="hairstyle"
                                                 data-id="@h.Id"
                                                 data-src="/Hairstyles/Image/@h.Id" />
                                        </div>
                                        <span class="small text-muted text-truncate d-block text-uppercase" style="font-size: 0.65rem;">@h.Name</span>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <div class="mb-5">
                        <h6 class="text-uppercase fw-bold small text-muted mb-4 letter-spacing-1">
                            @Localizer["FacialHair"]
                        </h6>
                        <div class="d-flex gap-3 overflow-x-auto pb-3" style="scrollbar-width: thin;">
                            <div class="text-center flex-shrink-0" onclick="selectNone('facial')" style="width: 70px; cursor: pointer;">
                                <div class="d-flex align-items-center justify-content-center mb-2" style="width: 100%; aspect-ratio: 4/5; border: 1px solid var(--border-subtle);">
                                    <i class="fa-solid fa-ban text-muted"></i>
                                </div>
                                <span class="small text-muted text-uppercase" style="font-size: 0.65rem;">None</span>
                            </div>
                            @if (facialHairs != null)
                            {
                                @foreach (var f in facialHairs)
                                {
                                    <div class="text-center flex-shrink-0 style-thumb-container" style="width: 70px; cursor: pointer;">
                                        <div class="gallery-img-wrapper mb-2 border border-secondary border-opacity-10" style="aspect-ratio: 4/5;">
                                            <img src="/FacialHairs/Image/@f.Id"
                                                 alt="@f.Name"
                                                 class="style-thumb gallery-img"
                                                 data-type="facial"
                                                 data-id="@f.Id"
                                                 data-src="/FacialHairs/Image/@f.Id" />
                                        </div>
                                        <span class="small text-muted text-truncate d-block text-uppercase" style="font-size: 0.65rem;">@f.Name</span>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <!-- Fine tuning omitted for minimal look, kept basics -->
                    <!-- AI Generation Panel -->
                    <div class="mt-auto border-top border-secondary border-opacity-25 pt-4">
                        <div class="form-group mb-4">
                            <label for="lookTitle" class="form-label text-uppercase small letter-spacing-1 text-muted">@Localizer["NameYourLook"]</label>
                            <input type="text" id="lookTitle" class="form-control bg-transparent border-secondary border-opacity-25 text-white rounded-0 shadow-none focus-border-accent" placeholder="E.g. The Milan Cut" maxlength="100">
                        </div>
                        
                        <div id="aiLoadingState" class="d-none text-center py-4 mb-3 border border-secondary border-opacity-25 bg-black">
                            <i class="fa-solid fa-wand-magic-sparkles fa-bounce mb-3" style="color: var(--accent-color); font-size: 1.5rem;"></i>
                            <h6 class="text-uppercase ls-1 small text-white mb-2">Generating Reality...</h6>
                            <p class="text-muted small mb-0" style="font-size: 0.7rem;">Please wait while our AI engine reconstructs your look.</p>
                        </div>

                        <div class="d-flex gap-2">
                            <button id="generateAiBtn" class="btn btn-luxury py-3 flex-grow-1 text-uppercase ls-1" style="font-size: 0.8rem;">
                                <i class="fa-solid fa-wand-magic-sparkles me-2"></i> Generate
                            </button>
                            <button id="saveLookBtn" class="btn btn-outline-secondary py-3 px-4 d-none" title="Save to Gallery">
                                <i class="fa-solid fa-download"></i>
                            </button>
                        </div>
                        <div id="saveLookMsg" class="text-center mt-3 text-uppercase small text-muted" style="font-size: 0.7rem; letter-spacing: 1px;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
}

<style>
    .style-thumb-container .gallery-img-wrapper {
        transition: all 0.3s ease;
    }
    .style-thumb-container:hover .gallery-img-wrapper {
        border-color: var(--text-primary) !important;
    }
    .style-thumb.selected-thumb {
        filter: grayscale(0%) !important;
    }
    /* Override for selected thumbnail border */
    .style-thumb.selected-thumb {
        border: 1px solid var(--accent-color) !important;
    }
</style>

@section Scripts {
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
        <script src="~/js/preview.js" asp-append-version="true"></script>
        
        <script>
            // Mark selected item border since we moved to wrapper architecture
            document.addEventListener('click', function(e) {
                if(e.target.classList.contains('style-thumb')) {
                    document.querySelectorAll('.style-thumb').forEach(t => t.classList.remove('selected-thumb'));
                    e.target.classList.add('selected-thumb');
                }
            });

            // SCROLL REVEAL OBSERVER
            const revealObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    } else {
                        // Fade out when scrolling up
                        entry.target.classList.remove('active');
                    }
                });
            }, { 
                threshold: 0.1,
                rootMargin: "0px 0px -50px 0px"
            });

            document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
        </script>
    }
}
