@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>
@{
    ViewData["Title"] = "Messages";
}

<div class="cyber-messages bg-black overflow-hidden" style="height: calc(100vh - 75px);">
    
    <!-- Scanline Overlay -->
    <div class="scanlines"></div>

    <div id="chatInterface" class="d-flex h-100 shadow-lg border-top border-secondary border-opacity-10 overflow-hidden chat-view-list">
        
        <!-- Sidebar: Conversations List -->
        <div id="chatSidebar" class="col-12 col-md-4 col-lg-3 border-end border-secondary border-opacity-10 bg-surface d-flex flex-column h-100 sidebar-panel">
            <div class="p-4 border-bottom border-secondary border-opacity-5 d-flex align-items-center justify-content-between">
                <h6 class="mb-0 fw-bold brand-font text-white letter-spacing-2 text-uppercase small">Transmissions</h6>
                <div class="badge bg-black border border-secondary border-opacity-25 text-accent ls-2 font-monospace" style="font-size: 0.6rem;">SYS.NET</div>
            </div>
            
            <div class="p-3 border-bottom border-secondary border-opacity-5 bg-black">
                <div class="input-group border border-secondary border-opacity-20 rounded-0 overflow-hidden bg-surface">
                    <span class="input-group-text bg-transparent border-0 px-3 py-2 text-muted">
                        <i class="fa-solid fa-magnifying-glass small"></i>
                    </span>
                    <input type="text" id="searchInput" class="form-control border-0 bg-transparent text-white shadow-none focus-none py-2 font-monospace" placeholder="Filter lines..." style="font-size: 0.75rem; letter-spacing: 0.1em;">
                </div>
            </div>

            <div class="chat-list overflow-auto flex-grow-1 custom-scrollbar py-0">
                @if (Model != null && Model.Any())
                {
                    foreach (var user in Model)
                    {
                        <div class="chat-item d-flex align-items-center p-3 border-bottom border-secondary border-opacity-5" data-userid="@user.Id" data-username="@user.UserName" style="cursor: pointer; position: relative; overflow: hidden;">
                            <div class="position-relative">
                                <img src="/Profile/GetPhoto?userId=@user.Id" class="rounded-0 border border-secondary border-opacity-10 grayscale-img" style="width: 48px; height: 48px; object-fit: cover;" alt="User avatar" onerror="this.src='https://ui-avatars.com/api/?name=@user.UserName&background=000&color=d4af37'">
                                <div class="active-dot"></div>
                            </div>
                            <div class="ms-3 flex-grow-1 overflow-hidden">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <h6 class="mb-0 text-truncate fw-bold text-white ls-1" style="font-size: 0.8rem;">@user.UserName</h6>
                                </div>
                                <p class="mb-0 text-truncate text-muted text-uppercase ls-1 font-monospace" style="font-size: 0.55rem;">Link Ready</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center p-5 text-muted text-uppercase ls-2 small opacity-50">
                        <i class="fa-solid fa-satellite-dish fs-3 mb-3 d-block"></i>
                        No links found.
                    </div>
                }
            </div>
        </div>

        <!-- Main Chat Area -->
        <div id="chatMain" class="col-12 col-md-8 col-lg-9 d-flex flex-column chat-main position-relative bg-black h-100 flex-grow-1 main-panel">
            <!-- Chat Header -->
            <div class="p-4 border-bottom border-secondary border-opacity-10 d-flex align-items-center justify-content-between bg-surface" style="z-index: 10;">
                <div class="d-flex align-items-center">
                    <button id="backToList" class="btn btn-ghost text-white border-secondary border-opacity-25 rounded-0 me-3 p-1" style="width: 38px; height: 38px;">
                        <i class="fa-solid fa-chevron-left"></i>
                    </button>
                    <div class="position-relative">
                        <img src="https://ui-avatars.com/api/?name=None&background=000&color=d4af37" id="chatHeaderAvatar" class="rounded-0 border border-secondary border-opacity-20" style="width: 42px; height: 42px; object-fit: cover;" alt="Avatar" onerror="this.src='https://ui-avatars.com/api/?name=' + currentUserName + '&background=000&color=d4af37'">
                    </div>
                    <div class="ms-3">
                        <h6 class="mb-0 fw-bold text-white ls-2 text-uppercase brand-font" id="chatHeaderName" style="font-size: 0.85rem;">Idle Connection</h6>
                        <small class="text-accent ls-1 font-monospace d-none" id="chatHeaderStatus" style="font-size: 0.55rem; letter-spacing: 2px;">• POINT-TO-POINT ENCRYPTED</small>
                    </div>
                </div>
            </div>

            <!-- Chat Messages -->
            <div id="chatMessages" class="chat-messages flex-grow-1 px-3 px-md-5 py-5 overflow-auto position-relative custom-scrollbar d-flex flex-column gap-3" style="background: radial-gradient(circle at 50% 50%, rgba(212, 175, 55, 0.02) 0%, transparent 100%);">
                <div class="my-auto text-center">
                    <div class="d-inline-block p-5 border border-secondary border-opacity-10 bg-surface shadow-sm">
                        <i class="fa-solid fa-terminal text-accent mb-4 d-block fs-3"></i>
                        <h6 class="fw-bold text-white ls-2 text-uppercase mb-3 small">Terminal Link Ready</h6>
                        <p class="text-muted small ls-1 mb-0 opacity-50" style="max-width: 300px;">Secure channel established. Please select a node from the directory to begin transmission.</p>
                    </div>
                </div>
            </div>

            <!-- Chat Input Toolbar -->
            <div class="p-4 bg-surface mt-auto border-top border-secondary border-opacity-10 shadow-lg" style="z-index: 10;">
                <div class="input-group bg-black border border-secondary border-opacity-30 rounded-0 p-1">
                    <input type="text" id="msgInput" class="form-control border-0 bg-transparent text-white shadow-none focus-none px-3 py-2 font-monospace" placeholder="Enter transmission..." style="font-size: 0.8rem; letter-spacing: 0.05em;">
                    <button id="sendBtn" class="btn btn-luxury py-0 px-4 rounded-0" type="button">
                        <i class="fa-solid fa-paper-plane small"></i>
                    </button>
                </div>
            </div>
            
        </div>
    </div>
</div>

<style>
    :root {
        --chat-radius: 24px;
        --chat-bubble-radius: 20px;
        --message-sent-bg: linear-gradient(135deg, #007bff 0%, #00d2ff 100%);
        --message-sent-shadow: 0 6px 15px rgba(0, 191, 255, 0.25);
        --accent-glow: 0 0 20px rgba(0, 191, 255, 0.2);
    }

    /* Container setup */
    .chat-container {
        height: 100%;
    }
    /* Cyber-Editorial Messages */
    .cyber-messages {
        position: relative;
        background: var(--bg-base);
        color: var(--text-primary);
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .scanlines {
        position: absolute;
        inset: 0;
        background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), 
                    linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));
        background-size: 100% 3px, 3px 100%;
        z-index: 5;
        pointer-events: none;
        opacity: 0.15;
    }

    .chat-item {
        border-radius: 0 !important;
        margin: 0 !important;
        transition: var(--transition-snappy);
    }
    .chat-item:hover {
        background: rgba(212, 175, 55, 0.05) !important;
    }
    .chat-item.active {
        background: rgba(212, 175, 55, 0.1) !important;
        border-left: 3px solid var(--accent-color) !important;
    }

    .grayscale-img {
        filter: grayscale(100%) contrast(1.1);
        transition: var(--transition-snappy);
    }
    .chat-item:hover .grayscale-img, .chat-item.active .grayscale-img {
        filter: grayscale(0%);
    }

    .active-dot {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 10px;
        height: 10px;
        background: var(--accent-color);
        border: 2px solid #000;
    }

    /* Focus Mode Logic */
    .chat-view-list .main-panel { display: none !important; }
    .chat-view-chat .sidebar-panel { display: none !important; }
    .chat-view-chat .main-panel { display: flex !important; width: 100% !important; flex: 0 0 100% !important; }

    @@media (min-width: 992px) {
        /* On large screens, maybe we want both? No, user explicitly asked for "others to disappear" */
        .chat-view-chat .main-panel { flex: 1; }
    }

    .message-bubble {
        max-width: 80%;
        padding: 0.9rem 1.4rem !important;
        border-radius: 8px !important;
        font-size: 0.95rem;
        line-height: 1.6;
        position: relative;
        border: 1px solid rgba(255,255,255,0.05);
        word-break: break-word;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    .message-bubble.sent {
        background: var(--accent-color) !important;
        color: #000 !important;
        font-weight: 500;
        margin-right: 10px;
    }
    .message-bubble.received {
        background: var(--bg-surface) !important;
        color: var(--text-primary) !important;
        border: 1px solid var(--border-subtle) !important;
        margin-left: 10px;
    }

    .message-wrapper {
        animation: messageSlide 0.3s ease-out forwards;
    }

    @@keyframes messageSlide {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .message-avatar {
        width: 32px !important;
        height: 32px !important;
        min-width: 32px !important;
        min-height: 32px !important;
        flex: 0 0 32px !important;
        object-fit: cover !important;
        border-radius: 0 !important; /* Sharp editorial look */
        border: 1px solid rgba(255,255,255,0.1) !important;
    }

    .custom-scrollbar::-webkit-scrollbar { width: 3px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(212, 175, 55, 0.1); }

    .btn-luxury {
        background: var(--accent-color);
        color: #000;
        border: none;
        letter-spacing: 2px;
        font-weight: 800;
        transition: var(--transition-snappy);
    }
    .btn-luxury:hover {
        background: var(--text-primary);
        color: var(--bg-base);
        transform: translateY(-2px);
    }

    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    .chat-item { animation: fadeIn 0.5s ease forwards; }
</style>

@section Scripts {
    <script>
        let currentUserId = null;
        let currentUserName = '';

        document.querySelectorAll('.chat-item').forEach(item => {
            item.addEventListener('click', function() {
                // Remove active from all
                document.querySelectorAll('.chat-item').forEach(i => i.classList.remove('active'));
                
                // Add active to clicked
                this.classList.add('active');

                // Switch to Chat View
                document.getElementById('chatInterface').classList.remove('chat-view-list');
                document.getElementById('chatInterface').classList.add('chat-view-chat');
                
                currentUserId = this.dataset.userid;
                currentUserName = this.dataset.username;
                
                // Update Header
                document.getElementById('chatHeaderName').textContent = currentUserName;
                document.getElementById('chatHeaderAvatar').src = `/Profile/GetPhoto?userId=${currentUserId}`;
                document.getElementById('chatHeaderStatus').classList.remove('d-none');
                
                // Load conversation using active user id
                loadChat(currentUserId);
            });
        });

        document.getElementById('backToList').addEventListener('click', function() {
            document.getElementById('chatInterface').classList.remove('chat-view-chat');
            document.getElementById('chatInterface').classList.add('chat-view-list');
        });

        async function loadChat(userId) {
            try {
                const response = await fetch(`/Messages/GetChat?userId=${userId}`);
                const data = await response.json();
                
                const chatContainer = document.getElementById('chatMessages');
                chatContainer.innerHTML = ''; // clear initial text/previous chat
                
                // --- Invitation Logic UI ---
                const inputArea = document.querySelector('.chat-input-toolbar'); // wait, I need to check the class
                const msgInput = document.getElementById('msgInput');
                const sendBtn = document.getElementById('sendBtn');
                
                // Clear any existing invitation overlays
                const existingOverlay = document.getElementById('invitationOverlay');
                if (existingOverlay) existingOverlay.remove();

                if (!data.isFriend) {
                    const overlay = document.createElement('div');
                    overlay.id = 'invitationOverlay';
                    overlay.className = 'p-3 bg-dark border-top border-secondary border-opacity-10 text-center';
                    
                    if (data.isPending) {
                        if (data.amRequester) {
                            overlay.innerHTML = `<span class="text-secondary small ls-1 text-uppercase"><i class="fa-solid fa-hourglass-start me-2"></i> Waiting for ${data.otherUser} to accept your transmission invitation.</span>`;
                            msgInput.disabled = true;
                            msgInput.placeholder = "Link pending...";
                            sendBtn.disabled = true;
                        } else {
                            overlay.innerHTML = `
                                <div class="d-flex flex-column align-items-center gap-3">
                                    <span class="text-white small ls-1 text-uppercase">${data.otherUser} wants to establish a direct link.</span>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-luxury px-4 py-2 small" onclick="handleInvite('${data.otherUserId}', 'accept')">Accept</button>
                                        <button class="btn btn-ghost border border-secondary border-opacity-25 px-4 py-2 small" onclick="handleInvite('${data.otherUserId}', 'reject')">Decline</button>
                                    </div>
                                </div>`;
                            msgInput.disabled = true;
                            msgInput.placeholder = "Accept invite to reply...";
                            sendBtn.disabled = true;
                        }
                    } else {
                        overlay.innerHTML = `<span class="text-accent small ls-1 text-uppercase"><i class="fa-solid fa-shield-halved me-2"></i> No active link. Your first message will serve as a connection request.</span>`;
                        msgInput.disabled = false;
                        msgInput.placeholder = "Send invitation packet...";
                        sendBtn.disabled = false;
                    }
                    document.querySelector('.chat-main').insertBefore(overlay, document.querySelector('.chat-main > .p-4.mt-auto'));
                } else {
                    msgInput.disabled = false;
                    msgInput.placeholder = "Transmit packet...";
                    sendBtn.disabled = false;
                }
                // --- End Invitation Logic UI ---

                if (data.messages && data.messages.length > 0) {
                    data.messages.forEach(msg => {
                        const timeStr = new Date(msg.sentAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                        appendMessage(msg.content, msg.isMine, timeStr);
                    });
                } else {
                    chatContainer.innerHTML = `
                        <div class="text-center text-muted small mt-5">
                            <span class="px-3 py-1 bg-body text-secondary rounded-pill border border-opacity-10">Start the conversation!</span>
                        </div>
                    `;
                }
                
                scrollToBottom();
            } catch (err) {
                console.error("Failed to load chat", err);
            }
        }

        async function handleInvite(userId, action) {
            const url = action === 'accept' ? '/Friends/AcceptFriend' : '/Friends/RemoveFriend';
            const res = await fetch(url + '?targetId=' + userId, { method: 'POST' });
            if (res.ok) {
                loadChat(userId); // reload
            }
        }

        function appendMessage(content, isMine, timeStr) {
            const chatContainer = document.getElementById('chatMessages');
            
            // If the only thing is the "start conversation" or "select a convo" pill, clear it first
            if (chatContainer.querySelector('.time-divider') || chatContainer.innerHTML.includes('Start the conversation')) {
                const textNodes = chatContainer.querySelectorAll('.text-center.text-muted.small');
                textNodes.forEach(node => node.remove());
            }

            const wrapper = document.createElement('div');
            wrapper.className = isMine 
                ? 'message-wrapper d-flex flex-row justify-content-end mb-4'
                : 'message-wrapper d-flex flex-row justify-content-start mb-4';

            if (isMine) {
                wrapper.innerHTML = `
                    <div class="d-flex flex-column align-items-end">
                        <div class="message-bubble sent p-3 rounded-4 shadow-sm text-white mb-1 px-4">${content}</div>
                        <small class="text-muted small me-2 message-time opacity-75">${timeStr} <i class="fa-solid fa-check-double text-primary ms-1"></i></small>
                    </div>`;
            } else {
                wrapper.innerHTML = `
                    <img src="/Profile/GetPhoto?userId=${currentUserId}" class="rounded-0 message-avatar me-2 align-self-end shadow-sm border" onerror="this.src='https://ui-avatars.com/api/?name=' + currentUserName + '&background=000&color=d4af37'">
                    <div>
                        <div class="message-bubble received p-3 rounded-4 shadow-sm mb-1 px-4">${content}</div>
                        <small class="text-muted small ms-2 message-time opacity-75">${timeStr}</small>
                    </div>`;
            }

            chatContainer.appendChild(wrapper);
        }
        
        function scrollToBottom() {
            const chatContainer = document.getElementById('chatMessages');
            setTimeout(() => {
                chatContainer.scrollTop = chatContainer.scrollHeight;
            }, 50);
        }

        async function sendMessage() {
            if (!currentUserId) return; // No chat selected
            
            const input = document.getElementById('msgInput');
            const content = input.value.trim();
            if (!content) return;
            
            input.value = ''; // clear input early for better UX
            
            try {
                const response = await fetch('/Messages/SendMessage', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ receiverId: currentUserId, content: content })
                });
                
                const data = await response.json();
                if (data.success) {
                    const timeStr = new Date(data.msg.sentAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                    appendMessage(data.msg.content, true, timeStr);
                    scrollToBottom();
                    
                    // Re-check status in case it was an invitation
                    loadChat(currentUserId);
                } else {
                    alert(data.message || "Failed to transmit.");
                    input.value = content; // restore
                }
            } catch(err) {
                console.error("Failed to send message", err);
            }
        }

        // Event listeners for sending
        document.getElementById('sendBtn').addEventListener('click', sendMessage);
        document.getElementById('msgInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                sendMessage();
            }
        });

        // Search logic
        document.getElementById('searchInput').addEventListener('input', function() {
            const query = this.value.toLowerCase();
            document.querySelectorAll('.chat-item').forEach(item => {
                const name = item.dataset.username.toLowerCase();
                if (name.includes(query)) {
                    item.classList.remove('d-none');
                } else {
                    item.classList.add('d-none');
                }
            });
        });
    </script>
}
