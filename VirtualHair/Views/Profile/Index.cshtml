@model VirtualHair.Controllers.ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<style>
    .profile-header-card {
        border: none;
        border-radius: 28px;
        background: var(--bs-body-bg);
        box-shadow: 0 10px 40px -10px rgba(0,0,0,0.08);
        overflow: hidden;
        margin-bottom: 2rem;
    }

    [data-bs-theme="dark"] .profile-header-card {
        background: #1c1c1e;
        box-shadow: 0 10px 40px -10px rgba(0,0,0,0.4);
    }


    .profile-avatar-wrapper {
        position: relative;
        padding-top: 2rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        z-index: 2;
    }

    .profile-avatar-container {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        border: 6px solid var(--bs-body-bg);
        overflow: hidden;
        background: #eee;
        box-shadow: 0 8px 16px rgba(0,0,0,0.1);
        cursor: pointer;
        transition: transform 0.3s ease;
        position: relative;
    }

    [data-bs-theme="dark"] .profile-avatar-container {
        border-color: #1c1c1e;
    }

    .profile-avatar-container:hover {
        transform: scale(1.05);
    }

    .profile-avatar-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .avatar-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.4);
        display: flex;
        justify-content: center;
        align-items: center;
        color: white;
        font-size: 1.5rem;
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    
    .profile-avatar-container:hover .avatar-overlay {
        opacity: 1;
    }

    .profile-info {
        padding: 2rem 2.5rem;
    }

    .settings-section {
        background: rgba(99, 102, 241, 0.03);
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(99, 102, 241, 0.08);
        transition: all 0.3s ease;
    }

    [data-bs-theme="dark"] .settings-section {
        background: rgba(255, 255, 255, 0.02);
        border-color: rgba(255, 255, 255, 0.05);
    }
    
    .settings-section:hover {
        background: rgba(99, 102, 241, 0.05);
        border-color: rgba(99, 102, 241, 0.15);
    }

    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
        color: #6366f1;
    }

    .custom-profile-input {
        border-radius: 12px !important;
        border: 1px solid #e2e8f0 !important;
        background: rgba(255,255,255,0.7) !important;
        transition: all 0.3s ease;
    }
    
    [data-bs-theme="dark"] .custom-profile-input {
        background: rgba(0,0,0,0.2) !important;
        border-color: #333 !important;
    }

    .custom-profile-input:focus {
        background: #fff !important;
        border-color: #6366f1 !important;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1) !important;
    }

    [data-bs-theme="dark"] .custom-profile-input:focus {
        background: #2a2a2a !important;
    }

    .btn-gradient {
        background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        color: white;
        border: none;
        transition: all 0.3s ease;
    }

    .btn-gradient:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(168, 85, 247, 0.4);
        color: white;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">

            @if (TempData["ProfileMsg"] != null)
            {
                <div class="alert alert-info alert-dismissible fade show rounded-4 shadow-sm mb-4 border-0 bg-primary bg-opacity-10 text-primary" role="alert">
                    <i class="fa-solid fa-circle-info me-2"></i>@TempData["ProfileMsg"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="profile-header-card">
                <div class="profile-avatar-wrapper">
                    <div class="profile-avatar-container mb-3" onclick="document.getElementById('profilePhotoInput').click()">
                        @if (Model.HasPhoto)
                        {
                            <img src="/Profile/Photo" alt="Profile" />
                        }
                        else
                        {
                            <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(Model.UserName))&size=256&background=random" alt="Profile" />
                        }
                        <div class="avatar-overlay">
                            <i class="fa-solid fa-camera"></i>
                        </div>
                    </div>
                    <div class="mb-2">
                        <h3 class="fw-bold mb-1">@Model.UserName</h3>
                        <p class="text-muted mb-0"><i class="fa-solid fa-envelope me-2 small"></i>@Model.Email</p>
                    </div>
                </div>

                <div class="profile-info">
                    <form asp-action="UpdateUserName" method="post" class="mb-4">
                        @Html.AntiForgeryToken()
                        <div class="settings-section">
                            <h5 class="fw-bold mb-3 d-flex align-items-center">
                                <i class="fa-solid fa-user-tag me-2 text-primary"></i> Personal Identity
                            </h5>
                            
                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                            
                            <div class="form-floating mb-3">
                                <input class="form-control custom-profile-input px-3" 
                                       asp-for="NewUserName" placeholder="Username" autocomplete="username" maxlength="60" />
                                <label class="px-3">Display Name</label>
                                <span asp-validation-for="NewUserName" class="text-danger small ms-2"></span>
                            </div>
                            
                            <p class="text-muted small mb-3">
                                <i class="fa-solid fa-circle-exclamation me-1"></i> Unique username for the community feed.
                            </p>

                            <button class="btn btn-gradient rounded-pill px-4" type="submit">
                                <i class="fa-solid fa-check me-2"></i>Apply Changes
                            </button>
                        </div>
                    </form>

                    <input id="profilePhotoInput" class="d-none" type="file" accept="image/*" />

                    <form id="cropUploadForm" asp-action="UploadPhoto" method="post" class="d-none">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="croppedImageBase64" id="croppedImageBase64" />
                    </form>

                    <div class="settings-section mb-0">
                        <h5 class="fw-bold mb-3 d-flex align-items-center">
                            <i class="fa-solid fa-shield-halved me-2 text-primary"></i> Security
                        </h5>
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <div class="fw-bold">Password</div>
                                <div class="text-muted small">Update your account security</div>
                            </div>
                            <a class="btn btn-outline-secondary rounded-pill px-4"
                               asp-area="Identity"
                               asp-page="/Account/Manage/ChangePassword">
                                <i class="fa-solid fa-key me-2"></i>Change
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Crop Modal -->
<div class="modal fade" id="cropModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Crop your profile photo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">

                <!-- SMALLER CROP SQUARE -->
                <div class="d-flex justify-content-center">
                    <div style="width: 320px; height: 320px;">
                        <img id="cropImage" alt="Crop" style="max-width:100%; display:block;" />
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-3">
                    <button type="button" class="btn btn-outline-secondary" id="zoomInBtn">
                        <i class="fa-solid fa-magnifying-glass-plus me-1"></i>Zoom In
                    </button>
                    <button type="button" class="btn btn-outline-secondary" id="zoomOutBtn">
                        <i class="fa-solid fa-magnifying-glass-minus me-1"></i>Zoom Out
                    </button>
                    <button type="button" class="btn btn-outline-secondary" id="rotateLeftBtn">
                        <i class="fa-solid fa-rotate-left me-1"></i>Rotate
                    </button>
                    <button type="button" class="btn btn-outline-secondary" id="resetBtn">
                        <i class="fa-solid fa-arrow-rotate-right me-1"></i>Reset
                    </button>
                </div>

                <div class="form-text mt-2">Tip: keep the face centered.</div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="cropAndUploadBtn">
                    <i class="fa-solid fa-scissors me-2"></i>Crop & Upload
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        let cropper = null;
        const input = document.getElementById('profilePhotoInput');
        const cropImage = document.getElementById('cropImage');
        const cropModalEl = document.getElementById('cropModal');
        const cropModal = new bootstrap.Modal(cropModalEl);

        input.addEventListener('change', () => {
            const file = input.files && input.files[0];
            if (!file) return;

            if (!file.type || !file.type.startsWith('image/')) {
                input.value = '';
                alert('Please choose a valid image.');
                return;
            }

            const url = URL.createObjectURL(file);
            cropImage.src = url;

            cropModal.show();
        });

        cropModalEl.addEventListener('shown.bs.modal', () => {
            if (cropper) cropper.destroy();

            cropper = new Cropper(cropImage, {
                aspectRatio: 1,
                viewMode: 1,
                dragMode: 'move',
                autoCropArea: 1,
                responsive: true,
                background: false
            });
        });

        cropModalEl.addEventListener('hidden.bs.modal', () => {
            if (cropper) {
                cropper.destroy();
                cropper = null;
            }
            if (cropImage.src && cropImage.src.startsWith('blob:')) {
                URL.revokeObjectURL(cropImage.src);
            }
            cropImage.removeAttribute('src');
            input.value = '';
        });

        document.getElementById('zoomInBtn').addEventListener('click', () => cropper && cropper.zoom(0.1));
        document.getElementById('zoomOutBtn').addEventListener('click', () => cropper && cropper.zoom(-0.1));
        document.getElementById('rotateLeftBtn').addEventListener('click', () => cropper && cropper.rotate(-90));
        document.getElementById('resetBtn').addEventListener('click', () => cropper && cropper.reset());

        document.getElementById('cropAndUploadBtn').addEventListener('click', () => {
            if (!cropper) return;

            const canvas = cropper.getCroppedCanvas({
                width: 512,
                height: 512,
                imageSmoothingEnabled: true
            });

            const dataUrl = canvas.toDataURL('image/png', 0.92);

            document.getElementById('croppedImageBase64').value = dataUrl;
            document.getElementById('cropUploadForm').submit();
        });
    </script>
}
