@using Microsoft.AspNetCore.Identity
@using VirtualHair.Data
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject ApplicationDbContext DbContext
@{
    var isAdmin = User.IsInRole("Admin");
    var isAuthenticated = SignInManager.IsSignedIn(User);
    int unreadMessagesCount = 0;
    if (isAuthenticated)
    {
        var currentUser = await UserManager.GetUserAsync(User);
        if (currentUser != null)
        {
            unreadMessagesCount = DbContext.Messages.Count(m => m.ReceiverId == currentUser.Id && !m.IsRead);
        }
    }

    var requestCulture = Context.Features.Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.UICulture.TwoLetterISOLanguageName ?? "en";
    bool isEmbed = Context.Request.Query.ContainsKey("embed");
}
<!DOCTYPE html>
<html lang="@currentCulture" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VIRTUALHAIR</title>
    
    <!-- Theme Restore Script (Prevents FOUC) -->
    <script>
        (function() {
            var theme = localStorage.getItem('vh-theme') || 'dark';
            document.documentElement.setAttribute('data-bs-theme', theme);
        })();
    </script>


    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <!-- Cropper.js -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
    
    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .page-transition { opacity: 0; transition: opacity 0.5s ease; }
        .page-transition.loaded { opacity: 1; }
    </style>
    @RenderSection("Styles", required: false)
</head>

<body class="@(isEmbed ? "bg-base" : "") page-transition">
    @if (!isEmbed)
    {
    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-editorial">
        <div class="container-fluid px-4 px-lg-5">
            <!-- Left: Logo -->
            <a class="navbar-brand m-0" asp-controller="Home" asp-action="Index">
                VIRTUAL<i>HAIR</i>
            </a>

            <!-- Center: Links (Desktop) -->
            <div class="d-none d-lg-flex flex-row align-items-center gap-4 mx-auto">
                <a asp-controller="Home" asp-action="Index" class="nav-link-editorial text-decoration-none">
                    <span data-localize="Home">@Localizer["Home"]</span>
                </a>
                @if (isAuthenticated)
                {
                    <a asp-controller="UserHairstyles" asp-action="Index" class="nav-link-editorial text-decoration-none">
                        <span data-localize="MyGallery">@Localizer["MyGallery"]</span>
                    </a>
                    <a asp-controller="Timeline" asp-action="Index" class="nav-link-editorial text-decoration-none">
                        <span data-localize="Feed">@Localizer["Hub"]</span>
                    </a>
                    @if (isAdmin)
                    {
                        <a asp-controller="Admin" asp-action="Index" class="nav-link-editorial text-decoration-none" style="color: var(--accent-color);">
                            <i class="fa-solid fa-crown me-1"></i> @Localizer["Dashboard"]
                        </a>
                    }
                }
            </div>

            <!-- Right: Actions & Menu -->
            <div class="d-flex align-items-center gap-3">
                <!-- Theme Switcher -->
                <button id="themeToggle" class="btn btn-ghost px-3 py-1 me-2" style="font-size: 0.9rem; border-color: var(--border-subtle); color: var(--text-primary);" title="@Localizer["DarkMode"]">
                    <i class="fa-solid fa-moon"></i>
                </button>

                <!-- Culture Switcher -->
                <form asp-controller="Culture" asp-action="SetLanguage" method="post" id="cultureForm" class="d-none d-md-block m-0">
                    <input type="hidden" name="returnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
                    <input type="hidden" name="culture" value="@(currentCulture == "en" ? "bg" : "en")" />
                    <button type="submit" class="btn btn-ghost px-3 py-1" style="font-size: 0.7rem; border-color: var(--border-subtle); color: var(--text-primary);" title="@Localizer[currentCulture == "en" ? "TranslateToBG" : "TranslateToEN"]">
                        @(currentCulture == "en" ? "BG" : "EN")
                    </button>
                </form>

                <button class="btn btn-ghost px-3 py-2 border-0 shadow-none d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasMenu">
                    <i class="fa-solid fa-bars fs-5"></i>
                </button>
                
                @if (isAuthenticated)
                {
                    <a asp-controller="Profile" asp-action="Index" class="d-none d-lg-inline-block rounded-circle overflow-hidden ms-2" style="width: 40px; height: 40px; border: 1px solid var(--border-subtle);">
                        <img src="/Profile/Photo" alt="Profile" class="w-100 h-100 object-fit-cover" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(User?.Identity?.Name ?? "User"))&background=000&color=d4af37';" />
                    </a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-ghost py-2 px-4 d-none d-lg-inline-block">
                        @Localizer["Login"]
                    </a>
                }
            </div>
        </div>
    </nav>

    <!-- Offcanvas Mobile/Sidebar Menu -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasMenu">
        <div class="offcanvas-header pb-0 border-0 pt-4 px-4">
            <span class="navbar-brand text-white m-0" style="font-size: 1.5rem; font-style: italic; color: var(--text-primary) !important;">
                VIRTUAL<i style="color: var(--accent-color); font-style: normal;">HAIR</i>
            </span>
            <button type="button" class="btn-close shadow-none" data-bs-dismiss="offcanvas"></button>
        </div>

        <div class="offcanvas-body pt-5 px-4 d-flex flex-column">
            <ul class="nav flex-column gap-2 mb-auto">
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Index" class="nav-link-editorial d-block py-3 border-bottom text-decoration-none">
                        <span data-localize="Home">@Localizer["Home"]</span>
                    </a>
                </li>

                @if (isAuthenticated)
                {
                    <li class="nav-item">
                        <a asp-controller="UserHairstyles" asp-action="Index" class="nav-link-editorial d-block py-3 border-bottom text-decoration-none" style="color: var(--accent-color);">
                            <span data-localize="MyGallery">@Localizer["MyGallery"]</span>
                        </a>
                    </li>       
                    <li class="nav-item mt-4 mb-2">
                        <span class="text-secondary small fw-bold text-uppercase letter-spacing-2">@Localizer["Community"]</span>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Feed" asp-action="Index" class="nav-link-editorial d-block py-3 border-bottom text-decoration-none">
                            <span data-localize="Feed">@Localizer["Feed"]</span>
                        </a>
                    </li>
                    @if (isAdmin)
                    {
                        <li class="nav-item mt-4 mb-2">
                            <span class="text-secondary small fw-bold text-uppercase letter-spacing-2" style="color: #d4af37 !important;">@Localizer["AdminPanel"]</span>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="Index" class="nav-link-editorial d-block py-3 border-bottom text-decoration-none" style="color: #d4af37;">
                                <i class="fa-solid fa-crown me-2"></i> @Localizer["Dashboard"]
                            </a>
                        </li>
                    }
                }
            </ul>

            <div class="mt-4 pt-4 border-top" style="border-color: var(--border-subtle) !important;">
                @if (isAuthenticated)
                {
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <img src="/Profile/Photo" alt="Profile" class="rounded-0 border border-secondary border-opacity-25" style="width: 50px; height: 50px; object-fit: cover;" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(User?.Identity?.Name ?? "User"))&background=000&color=d4af37';" />
                        <div>
                            <div class="fw-bold fs-6 m-0" style="color: var(--text-primary);">@User.Identity?.Name</div>
                            <a asp-controller="Profile" asp-action="Index" class="small text-muted text-decoration-none">@Localizer["ViewProfile"]</a>
                        </div>
                    </div>
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="m-0">
                        <button type="submit" class="btn btn-ghost w-100 py-3 text-secondary border-0 text-start px-0" style="color: var(--text-secondary);">
                            @Localizer["Logout"] <i class="fa-solid fa-arrow-right-long ms-2"></i>
                        </button>
                    </form>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-luxury w-100 py-3 mb-2">@Localizer["Login"]</a>
                    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-ghost w-100 py-3">@Localizer["Register"]</a>
                }
                
                <div class="d-flex gap-2 mt-4">
                    <button id="mobileThemeToggle" class="btn btn-ghost flex-grow-1 border border-secondary border-opacity-25 py-2 text-uppercase ls-1" style="font-size: 0.7rem;">
                        <i class="fa-solid fa-moon me-2"></i> @Localizer["DarkMode"]
                    </button>
                    <form asp-controller="Culture" asp-action="SetLanguage" method="post" id="mobileCultureForm" class="flex-grow-1 m-0">
                        <input type="hidden" name="returnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
                        <input type="hidden" name="culture" value="@(currentCulture == "en" ? "bg" : "en")" />
                        <button type="submit" class="btn btn-ghost w-100 py-2 border border-secondary border-opacity-25 text-uppercase ls-1" style="font-size: 0.7rem;">
                            @(currentCulture == "en" ? "BG" : "EN")
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    }

    <!-- Main Content -->
    <main role="main">
        @RenderBody()
    </main>

    @if (!isEmbed)
    {
    <!-- Footer -->
    <footer class="py-5 mt-auto text-center">
        <div class="container-fluid">
            <hr class="mb-4" style="border-color: var(--border-subtle); max-width: 400px; margin: 0 auto;" />
            <h4 class="brand-font fs-3 text-white mb-2" style="font-style: italic;">VIRTUAL<i style="color: var(--accent-color); font-style: normal;">HAIR</i></h4>
            <p class="mb-0 fw-medium letter-spacing-1 text-uppercase" style="color: var(--text-muted); font-size: 0.65rem;">
                &copy; @DateTime.Now.Year. THE FUTURE OF STYLING.
            </p>
        </div>
    </footer>
    }

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Smooth Language Switch Animation
        const cultureForm = document.getElementById('cultureForm');
        const mCultureForm = document.getElementById('mobileCultureForm');
        
        const attachTransition = (form) => {
            if (form) {
                form.addEventListener('submit', async function(e) {
                    e.preventDefault();
                    document.body.style.transition = 'opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1)';
                    document.body.style.opacity = '0';
                    setTimeout(() => form.submit(), 500);
                });
            }
        };
        
        attachTransition(cultureForm);
        attachTransition(mCultureForm);

        // Theme Toggle Logic
        const themeToggle = document.getElementById('themeToggle');
        const mobileThemeToggle = document.getElementById('mobileThemeToggle');
        const htmlEl = document.documentElement;

        function setTheme(theme) {
            htmlEl.classList.add('theme-transitioning');
            htmlEl.setAttribute('data-bs-theme', theme);
            localStorage.setItem('vh-theme', theme);
            
            const isDark = theme === 'dark';
            const iconClass = isDark ? 'fa-sun' : 'fa-moon';
            
            if(themeToggle) {
                themeToggle.innerHTML = `<i class="fa-solid ${iconClass}"></i>`;
            }
            if(mobileThemeToggle) {
                const text = isDark ? '@Localizer["LightMode"]' : '@Localizer["DarkMode"]';
                mobileThemeToggle.innerHTML = `<i class="fa-solid ${iconClass} me-2"></i> ${text}`;
            }

            // Remove transition class after animation finishes
            setTimeout(() => {
                htmlEl.classList.remove('theme-transitioning');
            }, 400);
        }

        const savedTheme = localStorage.getItem('vh-theme') || 'dark';
        setTheme(savedTheme);

        window.addEventListener('storage', (e) => {
            if (e.key === 'vh-theme') setTheme(e.newValue);
        });

        function toggleThemeAction() {
            const currentTheme = htmlEl.getAttribute('data-bs-theme');
            setTheme(currentTheme === 'dark' ? 'light' : 'dark');
        }

        if(themeToggle) themeToggle.addEventListener('click', toggleThemeAction);
        if(mobileThemeToggle) mobileThemeToggle.addEventListener('click', toggleThemeAction);

        // Page Transition Trigger
        window.addEventListener('load', () => {
            document.body.classList.add('loaded');
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
