@model VirtualHair.Models.Post
@{
    ViewData["Title"] = "Modify Transmission";
}

<div class="container py-5" style="max-width: 700px;">
    <div class="editorial-card fade-up">
        <h3 class="brand-font mb-4 text-white ls-2 text-uppercase d-flex align-items-center gap-3">
            <i class="fa-solid fa-pen-fancy text-accent"></i> Update Segment
        </h3>
        <p class="text-secondary small ls-1 text-uppercase mb-5 border-bottom border-secondary border-opacity-10 pb-3">Recoding metadata for post #@Model.Id</p>

        <form asp-action="Edit" method="post" class="mt-4">
            <input type="hidden" asp-for="Id" />
            
            <div class="mb-4 text-center">
                <img src="@Model.ImagePath" class="img-fluid border border-secondary border-opacity-25 shadow-sm mb-3" style="max-height: 300px;" />
                <div class="text-muted small ls-1 font-monospace opacity-50">ORIGINAL MEDIA (READ-ONLY)</div>
            </div>

            <div class="mb-4">
                <label class="form-label">Description</label>
                <textarea name="description" class="form-control" rows="4">@Model.Description</textarea>
            </div>

            <div class="mb-5">
                <label class="form-label">Style Tags (comma separated)</label>
                <input type="text" name="tags" class="form-control" value="@Model.Tags" placeholder="e.g. fade, sharp, clean" />
            </div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-luxury flex-grow-1 py-3">Commit Changes</button>
                <a asp-action="Index" class="btn btn-ghost py-3 px-5">Cancel</a>
            </div>
        </form>
    </div>
</div>
