@model VirtualHair.Models.UserHairstyle
@{
    ViewData["Title"] = "Delete Look";
}

<div class="container py-5 fade-up">
    <div class="mx-auto" style="max-width: 600px;">
        <div class="bg-surface border border-secondary border-opacity-25 rounded-0 p-5">
            <div class="text-center mb-5">
                <div class="d-inline-flex align-items-center justify-content-center border border-danger border-opacity-50 text-danger mb-4" style="width: 60px; height: 60px; border-radius: 0; background: rgba(220, 53, 69, 0.05);">
                    <i class="fa-solid fa-triangle-exclamation fs-3"></i>
                </div>
                <h3 class="display-6 brand-font fw-bold text-white mb-2">Delete Validation</h3>
                <p class="text-secondary small text-uppercase ls-1">Permanent Data Removal</p>
                <div class="alert mt-4 rounded-0 small text-uppercase ls-1 d-inline-block px-4 py-2" style="background: rgba(220, 53, 69, 0.05); border: 1px solid rgba(220, 53, 69, 0.2); color: #ef4444;">
                    Warning: This action cannot be reversed
                </div>
            </div>

            <div class="bg-black border border-secondary border-opacity-25 p-4 mb-5">
                <div class="row g-4 align-items-center">
                    <div class="col-sm-5">
                        <div class="border border-secondary border-opacity-10 ratio ratio-1x1 bg-surface d-flex align-items-center justify-content-center rounded-0">
                            <img src="@(Model.ImageData != null ? $"/UserHairstyles/Image/{Model.Id}" : "/images/no-image.png")" class="w-100 h-100" style="object-fit: cover; border-radius: 0;" alt="Preview" />
                        </div>
                    </div>
                    <div class="col-sm-7">
                        <div class="d-flex flex-column gap-3">
                            <div>
                                <div class="text-secondary small text-uppercase ls-1" style="font-size: 0.65rem;">Look Identifier</div>
                                <div class="fw-bold text-white fs-5">@Model.Title</div>
                            </div>
                            <div>
                                <div class="text-secondary small text-uppercase ls-1" style="font-size: 0.65rem;">Creation Date</div>
                                <div class="text-white">@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <form asp-action="DeleteConfirmed" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="d-flex flex-column flex-sm-row gap-3">
                    <button type="submit" class="btn btn-ghost border-danger border-opacity-50 text-danger flex-grow-1 py-3 text-uppercase ls-1 rounded-0" style="font-size: 0.75rem; background: rgba(220, 53, 69, 0.05);">
                        <i class="fa-solid fa-trash-can me-2"></i> Confirm Deletion
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary flex-grow-1 py-3 text-uppercase ls-1 rounded-0" style="font-size: 0.75rem;">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Toasts -->
<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080">
    <div id="toastMsg" class="toast align-items-center text-bg-success border-0 rounded-0" role="alert">
        <div class="d-flex">
            <div class="toast-body ls-1 small text-uppercase" id="toastBody">Deleted successfully.</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto shadow-none" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const success = '@(TempData["SuccessMessage"] ?? "")';
            const error = '@(TempData["ErrorMessage"] ?? "")';
            if (success || error) {
                const toast = document.getElementById('toastMsg');
                const body = document.getElementById('toastBody');
                if (error) {
                    toast.classList.remove('text-bg-success');
                    toast.classList.add('text-bg-danger');
                    body.textContent = error;
                } else {
                    toast.classList.remove('text-bg-danger');
                    toast.classList.add('text-bg-success');
                    body.textContent = success;
                }
                new bootstrap.Toast(toast, { delay: 3000 }).show();
            }
        })();
    </script>
}
