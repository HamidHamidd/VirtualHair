@model VirtualHair.Models.UserHairstyle
@{
    ViewData["Title"] = "Look Details";
    var lookImg = Model.ImageData != null ? $"/UserHairstyles/Image/{Model.Id}" : "/images/no-image.png";
    var hairstyleImg = Model.Hairstyle?.ImageData != null ? $"/Hairstyles/Image/{Model.Hairstyle.Id}" : null;
    var facialImg = Model.FacialHair?.ImageData != null ? $"/FacialHairs/Image/{Model.FacialHair.Id}" : null;
}

<div class="container py-5 fade-up">
    <!-- Breadcrumb & Header -->
    <div class="d-flex align-items-center justify-content-between mb-5 border-bottom border-light border-opacity-10 pb-4">
        <div>
            <h2 class="display-6 brand-font fw-bold text-white mb-2">Look Details</h2>
            <p class="text-secondary text-uppercase ls-1 small mb-0">Generated Visualizations</p>
        </div>
        <a asp-action="Index" class="btn btn-ghost px-4 py-2 border border-secondary border-opacity-25 rounded-0 text-uppercase ls-1" style="font-size: 0.75rem;">
            <i class="fa-solid fa-arrow-left me-2"></i> Gallery
        </a>
    </div>

    <div class="row g-4 mb-5">
        <!-- LEFT: Main preview -->
        <div class="col-lg-7">
            <div class="bg-surface border border-secondary border-opacity-25 p-4 rounded-0 position-relative h-100 d-flex align-items-center justify-content-center">
                <img src="@lookImg" alt="Look preview" class="img-fluid" style="max-height: 700px; object-fit: contain;" />
            </div>
        </div>

        <!-- RIGHT: Info -->
        <div class="col-lg-5">
            <div class="bg-surface border border-secondary border-opacity-25 p-4 rounded-0 h-100 d-flex flex-column">
                
                <!-- Title -->
                <div class="mb-5 pb-4 border-bottom border-secondary border-opacity-25">
                    <h3 class="fw-bold brand-font text-white mb-2" style="font-size: 2rem; line-height: 1.2;">@(string.IsNullOrWhiteSpace(Model.Title) ? "Untitled Look" : Model.Title)</h3>
                    <div class="text-secondary text-uppercase ls-1" style="font-size: 0.65rem;">
                        <i class="fa-regular fa-clock me-1"></i> Saved on @Model.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
                    </div>
                </div>

                <!-- Info list -->
                <h6 class="fw-bold mb-4 text-uppercase ls-1 text-white border-start border-3 px-3" style="border-color: var(--accent-color) !important; font-size: 0.8rem;">
                    Configuration
                </h6>
                <div class="d-flex flex-column gap-3 mb-5">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-secondary text-uppercase ls-1" style="font-size: 0.7rem;">
                            <i class="fa-solid fa-scissors opacity-50 me-2"></i>Hairstyle
                        </span>
                        <span class="fw-bold text-white text-end">@(Model.Hairstyle?.Name ?? "Original Hair")</span>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-secondary text-uppercase ls-1" style="font-size: 0.7rem;">
                            <i class="fa-solid fa-user-ninja opacity-50 me-2"></i>Facial Hair
                        </span>
                        <span class="fw-bold text-white text-end">@(Model.FacialHair?.Name ?? "No additions")</span>
                    </div>
                </div>

                <!-- Mini previews -->
                <h6 class="fw-bold mb-4 text-uppercase ls-1 text-white border-start border-3 px-3" style="border-color: var(--accent-color) !important; font-size: 0.8rem;">
                    Components
                </h6>
                <div class="row g-3 mb-5 flex-grow-1">
                    <div class="col-6">
                        <div class="border border-secondary border-opacity-25 p-2 rounded-0 text-center bg-black">
                            <div class="mb-2 mx-auto d-flex align-items-center justify-content-center" style="aspect-ratio: 1/1; background: var(--bg-surface);">
                                @if (!string.IsNullOrWhiteSpace(hairstyleImg))
                                {
                                    <img src="@hairstyleImg" class="w-100 h-100 object-fit-contain p-2" alt="Hairstyle" />
                                }
                                else
                                {
                                    <i class="fa-solid fa-ban text-secondary opacity-50 fs-2"></i>
                                }
                            </div>
                            <span class="text-secondary text-uppercase ls-1" style="font-size: 0.65rem;">Hair</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="border border-secondary border-opacity-25 p-2 rounded-0 text-center bg-black">
                            <div class="mb-2 mx-auto d-flex align-items-center justify-content-center" style="aspect-ratio: 1/1; background: var(--bg-surface);">
                                @if (!string.IsNullOrWhiteSpace(facialImg))
                                {
                                    <img src="@facialImg" class="w-100 h-100 object-fit-contain p-2" alt="Facial hair" />
                                }
                                else
                                {
                                    <i class="fa-solid fa-ban text-secondary opacity-50 fs-2"></i>
                                }
                            </div>
                            <span class="text-secondary text-uppercase ls-1" style="font-size: 0.65rem;">Beard</span>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="d-flex gap-2 pt-4 border-top border-secondary border-opacity-25 mt-auto">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary flex-grow-1 rounded-0 py-3 text-uppercase ls-1" style="font-size: 0.75rem;">
                        <i class="fa-solid fa-pen-to-square me-2"></i> Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-ghost border-danger border-opacity-50 text-danger flex-grow-1 rounded-0 py-3 text-uppercase ls-1" style="font-size: 0.75rem; background: rgba(220, 53, 69, 0.05);">
                        <i class="fa-solid fa-trash-can me-2"></i> Delete
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Toast -->
<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080">
    <div id="toastMsg" class="toast align-items-center text-bg-success border-0 rounded-0" role="alert">
        <div class="d-flex">
            <div class="toast-body fw-medium" id="toastBody">Action completed.</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto shadow-none" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const success = '@(TempData["SuccessMessage"] ?? "")';
            const error = '@(TempData["ErrorMessage"] ?? "")';
            if (success || error) {
                const toast = document.getElementById('toastMsg');
                const body = document.getElementById('toastBody');
                if (error) {
                    toast.classList.replace('text-bg-success', 'text-bg-danger');
                    body.innerHTML = '<i class="fa-solid fa-triangle-exclamation me-2"></i>' + error;
                } else {
                    toast.classList.replace('text-bg-danger', 'text-bg-success');
                    body.innerHTML = '<i class="fa-solid fa-check-circle me-2"></i>' + success;
                }
                new bootstrap.Toast(toast, { delay: 4000 }).show();
            }
        })();
    </script>
}
