@model VirtualHair.Models.UserHairstyle
@{
    ViewData["Title"] = "Edit Look";
    var lookImg = Model.ImageData != null ? $"/UserHairstyles/Image/{Model.Id}" : "/images/no-image.png";
    var hairstyleImg = Model.Hairstyle?.ImageData != null ? $"/Hairstyles/Image/{Model.Hairstyle.Id}" : null;
    var facialImg = Model.FacialHair?.ImageData != null ? $"/FacialHairs/Image/{Model.FacialHair.Id}" : null;
}

<div class="container py-5 fade-up">
    <!-- Breadcrumb & Header -->
    <div class="d-flex align-items-center justify-content-between mb-5 border-bottom border-light border-opacity-10 pb-4">
        <div>
            <h2 class="display-6 brand-font fw-bold text-white mb-2">Edit Details</h2>
            <p class="text-secondary text-uppercase ls-1 small mb-0">Update Look Configuration</p>
        </div>
        <a asp-action="Index" class="btn btn-ghost px-4 py-2 border border-secondary border-opacity-25 rounded-0 text-uppercase ls-1" style="font-size: 0.75rem;">
            <i class="fa-solid fa-arrow-left me-2"></i> Cancel
        </a>
    </div>

    <div class="row g-4 mb-5">
        <!-- LEFT SIDE: Current Look Preview -->
        <div class="col-lg-7">
            <div class="bg-surface border border-secondary border-opacity-25 rounded-0 position-relative h-100 d-flex align-items-center justify-content-center bg-black p-4">
                <img src="@lookImg" class="img-fluid" style="max-height: 700px; object-fit: contain;" alt="Look preview" />
            </div>
        </div>

        <!-- RIGHT SIDE: Edit Form -->
        <div class="col-lg-5">
            <div class="bg-surface border border-secondary border-opacity-25 p-4 rounded-0 h-100 d-flex flex-column">
                <form asp-action="Edit" method="post" enctype="multipart/form-data" novalidate class="d-flex flex-column h-100">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 font-monospace small"></div>

                    <!-- Title -->
                    <div class="mb-5">
                        <label asp-for="Title" class="form-label text-uppercase ls-1 text-secondary" style="font-size: 0.75rem;">Look Name</label>
                        <input asp-for="Title" class="form-control bg-transparent border-secondary border-opacity-25 text-white rounded-0 shadow-none focus-border-accent py-3" />
                        <span asp-validation-for="Title" class="text-danger small font-monospace"></span>
                    </div>

                    <!-- Hairstyle -->
                    <h6 class="fw-bold mb-4 text-uppercase ls-1 text-white border-start border-3 px-3" style="border-color: var(--accent-color) !important; font-size: 0.8rem;">
                        Base Configuration
                    </h6>
                    
                    <div class="mb-4">
                        <label asp-for="HairstyleId" class="form-label text-uppercase ls-1 text-secondary" style="font-size: 0.7rem;">Hairstyle Data</label>
                        <select asp-for="HairstyleId"
                                class="form-select bg-black border-secondary border-opacity-25 text-white rounded-0 shadow-none focus-border-accent py-2"
                                asp-items="@(new SelectList(ViewBag.Hairstyles, "Id", "Name", Model?.HairstyleId))">
                            <option value="">-- Original Hair --</option>
                        </select>
                        <span asp-validation-for="HairstyleId" class="text-danger small font-monospace"></span>
                    </div>

                    <!-- Facial Hair -->
                    <div class="mb-5">
                        <label asp-for="FacialHairId" class="form-label text-uppercase ls-1 text-secondary" style="font-size: 0.7rem;">Facial Structure</label>
                        <select asp-for="FacialHairId"
                                class="form-select bg-black border-secondary border-opacity-25 text-white rounded-0 shadow-none focus-border-accent py-2"
                                asp-items="@(new SelectList(ViewBag.FacialHairs, "Id", "Name", Model?.FacialHairId))">
                            <option value="">-- No Additions --</option>
                        </select>
                        <span asp-validation-for="FacialHairId" class="text-danger small font-monospace"></span>
                    </div>

                    <!-- MINI PREVIEWS -->
                    <h6 class="fw-bold mb-4 text-uppercase ls-1 text-white border-start border-3 px-3" style="border-color: var(--accent-color) !important; font-size: 0.8rem;">
                        Current Assets
                    </h6>
                    <div class="row g-3 mb-5">
                        <div class="col-6">
                            <div class="border border-secondary border-opacity-25 p-2 rounded-0 text-center bg-black">
                                <span class="text-secondary text-uppercase ls-1 d-block mb-2" style="font-size: 0.65rem;">Hairstyle</span>
                                <div class="mx-auto d-flex align-items-center justify-content-center border border-secondary border-opacity-10" style="aspect-ratio: 1/1; background: var(--bg-surface);">
                                    @if (!string.IsNullOrWhiteSpace(hairstyleImg))
                                    {
                                        <img src="@hairstyleImg" class="w-100 h-100 object-fit-contain p-2" alt="Hairstyle" />
                                    }
                                    else
                                    {
                                        <div class="text-muted small text-uppercase ls-1" style="font-size: 0.6rem;">None</div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="border border-secondary border-opacity-25 p-2 rounded-0 text-center bg-black">
                                <span class="text-secondary text-uppercase ls-1 d-block mb-2" style="font-size: 0.65rem;">Facial Hair</span>
                                <div class="mx-auto d-flex align-items-center justify-content-center border border-secondary border-opacity-10" style="aspect-ratio: 1/1; background: var(--bg-surface);">
                                    @if (!string.IsNullOrWhiteSpace(facialImg))
                                    {
                                        <img src="@facialImg" class="w-100 h-100 object-fit-contain p-2" alt="Facial hair" />
                                    }
                                    else
                                    {
                                        <div class="text-muted small text-uppercase ls-1" style="font-size: 0.6rem;">None</div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="mt-auto pt-4 border-top border-secondary border-opacity-25">
                        <button type="submit" class="btn btn-luxury w-100 py-3 text-uppercase ls-1" style="font-size: 0.8rem;">
                            <i class="fa-solid fa-floppy-disk me-2"></i> Update Save Data
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

<!-- Toast -->
<div class="position-fixed top-0 end-0 p-3" style="z-index: 1080">
    <div id="toastMsg" class="toast align-items-center text-bg-success border-0 rounded-0" role="alert">
        <div class="d-flex">
            <div class="toast-body ls-1 small text-uppercase" id="toastBody">Updated successfully.</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto shadow-none" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const success = '@(TempData["SuccessMessage"] ?? "")';
            const error = '@(TempData["ErrorMessage"] ?? "")';

            if (success || error) {
                const toast = document.getElementById('toastMsg');
                const body = document.getElementById('toastBody');

                if (error) {
                    toast.classList.remove('text-bg-success');
                    toast.classList.add('text-bg-danger');
                    body.textContent = error;
                } else {
                    toast.classList.add('text-bg-success');
                    body.textContent = success;
                }

                new bootstrap.Toast(toast, { delay: 3000 }).show();
            }
        })();
    </script>
}
