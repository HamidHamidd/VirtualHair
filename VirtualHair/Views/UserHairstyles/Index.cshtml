@model IEnumerable<VirtualHair.Models.UserHairstyle>
@{
    ViewData["Title"] = "My Gallery";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0"><i class="fa-solid fa-images me-2" style="color: #a855f7;"></i>My Gallery</h2>

        <a asp-action="Create" class="btn btn-premium-gradient text-white rounded-pill px-4 shadow-sm" style="background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%); border:none;">
            <i class="fa-solid fa-plus me-2"></i>Add New Look
        </a>
    </div>

    <!-- Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success text-center rounded-pill shadow-sm">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger text-center rounded-pill shadow-sm">@TempData["ErrorMessage"]</div>
    }

    <!-- No items -->
    @if (!Model.Any())
    {
        <div class="text-center text-muted mt-5">
            <i class="fa-regular fa-image fa-4x mb-3"></i>
            <h5 class="fw-semibold">No looks yet</h5>
            <p class="small">Create your first look to see it here.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">

            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="gallery-card shadow-sm">

                        <!-- Image -->
                        <div class="gallery-img-wrapper">
                            <img src="@(item.ImageData != null ? $"/UserHairstyles/Image/{item.Id}" : "/images/no-image.png")"
                                 class="gallery-img"
                                 alt="@item.Title" />
                        </div>

                        <!-- Info -->
                        <div class="gallery-info p-3">

                            <h5 class="fw-semibold text-truncate mb-2">
                                @item.Title
                            </h5>

                            <div class="small text-muted mb-2">
                                <i class="fa-solid fa-scissors me-1"></i>@item.Hairstyle?.Name
                                @if (item.FacialHair != null)
                                {
                                    <span> | <i class="fa-solid fa-beard me-1"></i>@item.FacialHair?.Name</span>
                                }
                            </div>

                            <div class="small text-secondary mb-3">
                                <i class="fa-regular fa-calendar me-1"></i>
                                @item.CreatedAt.ToShortDateString()
                            </div>

                            <!-- Action buttons -->
                            <div class="d-flex justify-content-between">
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-outline-info btn-sm rounded-pill px-3">
                                    View
                                </a>

                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-outline-warning btn-sm rounded-pill px-3">
                                    Edit
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                    Delete
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            }

        </div>
    }
</div>
